# Goal Atlas environment variables
#
# Copy this file to .env and fill in real values.
# .env is gitignored (see .gitignore) — never commit secrets.
#
#   cp .env.example .env

# ── YouTube Data API v3 ─────────────────────────────────────────────────────
# Used by VideoLinkScout (app/services/video_link_scout.rb) and the
# `rake video_links:suggest_for_*` tasks to suggest official video URLs.
#
# Setup:
#   1. Enable YouTube Data API v3:
#      https://console.cloud.google.com/apis/library/youtube.googleapis.com
#   2. Create an API key:
#      https://console.cloud.google.com/apis/credentials
#   3. Restrict it to "YouTube Data API v3" under API restrictions
YOUTUBE_API_KEY=

# ── Admin user seed ─────────────────────────────────────────────────────────
# Used by db/seeds/admin_user.rb to create the initial admin User row.
# - ADMIN_EMAIL: required. Email for the admin login.
# - ADMIN_PASSWORD: optional. If set, used verbatim; if omitted, the seed
#   generates a random 32-char password and prints it once to stdout.
# Re-running the seed is a no-op once any admin user exists.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── OpenAI (gpt-image-1) ────────────────────────────────────────────────────
# Used by PortraitStylizer (app/services/portrait_stylizer.rb) and the
# "Generate new stylized portrait" admin button. Get a key from
# https://platform.openai.com/api-keys (requires a payment method on file).
OPENAI_API_KEY=

# ── Gemini (timestamp scout) ────────────────────────────────────────────────
# Used by GeminiTimestampScout (app/services/gemini_timestamp_scout.rb).
GEMINI_API_KEY=

# ── Kamal deploy secrets ────────────────────────────────────────────────────
# Sourced before running `bin/kamal …` (e.g. `set -a; source .env; set +a`).
# See .kamal/secrets for how each is consumed.

# GitHub Container Registry token for ghcr.io pushes. Create at
# https://github.com/settings/tokens/new with scope: write:packages
KAMAL_REGISTRY_PASSWORD=

# Postgres password for the production goal_atlas user. Used both by the
# Rails app (via DATABASE config) and the Postgres accessory at startup.
# Generate with: openssl rand -base64 32
GOAL_ATLAS_DATABASE_PASSWORD=
