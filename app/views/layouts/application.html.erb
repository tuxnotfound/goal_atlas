<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "The Goal Atlas" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="The Goal Atlas">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#0a3520] text-[#e8d99c] min-h-screen flex flex-col">
    <header class="bg-[#082619] text-[#e8d99c] border-b border-[#c89942]/30">
      <div class="max-w-7xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-x-6 gap-y-3">
        <%= link_to root_path, class: "font-bold text-xl tracking-tight text-[#f0c870] hover:text-[#fef0c8] transition shrink-0" do %>
          The Goal Atlas
        <% end %>

        <%= form_with url: search_path, method: :get, local: true,
                      class: "order-3 sm:order-2 w-full sm:w-auto sm:flex-1 sm:max-w-md" do |f| %>
          <%= f.search_field :q, value: params[:q],
                placeholder: "Search teams, players, tournaments…",
                class: "w-full px-3 py-1.5 rounded-md bg-[#051a0f] placeholder-[#8aa898] border border-[#c89942]/30 focus:border-[#c89942] focus:outline-none text-sm text-[#e8d99c]",
                autocomplete: "off" %>
        <% end %>

        <nav class="order-2 sm:order-3 flex items-center gap-5 text-sm">
          <%= link_to "World Cups", tournaments_path, class: "hover:text-[#f0c870] transition" %>
          <%= link_to "Matches",    matches_path,     class: "hover:text-[#f0c870] transition" %>
          <%= link_to "Goals",      goals_path,       class: "hover:text-[#f0c870] transition" %>
          <% if request.path.start_with?("/admin") %>
            <span class="text-[#c89942]/50">·</span>
            <%= link_to "Suggest videos", admin_video_link_suggestions_path,
                        class: "hover:text-[#fef0c8] transition text-[#f0c870]" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="grow max-w-7xl w-full mx-auto px-6 py-8">
      <%= yield %>
    </main>

    <footer class="bg-[#082619] border-t border-[#c89942]/20 text-xs text-[#8aa898]">
      <div class="max-w-7xl mx-auto px-6 py-6 leading-relaxed">
        This is an independent football history project. Videos are linked or embedded
        from official/public sources where available. All trademarks, footage, and media
        belong to their respective owners. Not affiliated with FIFA.
      </div>
    </footer>
  </body>
</html>
