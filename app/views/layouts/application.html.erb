<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Goal Atlas" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Goal Atlas">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-50 text-stone-900 min-h-screen flex flex-col">
    <header class="bg-emerald-900 text-emerald-50 border-b border-emerald-800">
      <div class="max-w-5xl mx-auto px-5 py-4 flex items-center justify-between gap-6">
        <%= link_to root_path, class: "font-bold text-xl tracking-tight hover:text-white transition shrink-0" do %>
          Goal Atlas
        <% end %>

        <nav class="flex items-center gap-5 text-sm">
          <%= link_to "World Cups", tournaments_path, class: "hover:text-white transition" %>
          <%= link_to "Matches",    matches_path,     class: "hover:text-white transition" %>
        </nav>
      </div>
    </header>

    <main class="grow max-w-5xl w-full mx-auto px-5 py-8">
      <%= yield %>
    </main>

    <footer class="bg-stone-100 border-t border-stone-200 text-xs text-stone-500">
      <div class="max-w-5xl mx-auto px-5 py-6 leading-relaxed">
        This is an independent football history project. Videos are linked or embedded
        from official/public sources where available. All trademarks, footage, and media
        belong to their respective owners. Not affiliated with FIFA.
      </div>
    </footer>
  </body>
</html>
