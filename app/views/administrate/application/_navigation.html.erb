<%#
  Overrides Administrate's default navigation partial.

  - Skips routes inside the admin namespace that don't have a corresponding
    *Dashboard class (e.g. our custom Admin::VideoLinkSuggestionsController).
  - Appends an explicit "Suggest videos" link so the custom controller stays
    reachable from the admin sidebar.
%>

<nav class="navigation">
  <%= link_to(t("administrate.navigation.back_to_app"), root_url, class: "button button--alt button--nav") if defined?(root_url) %>

  <% Administrate::Namespace.new(namespace).resources_with_index_route.each do |resource| %>
    <% dashboard_class = "#{resource.to_s.singularize.camelize}Dashboard".safe_constantize %>
    <% next unless dashboard_class %>
    <%= link_to(
      display_resource_name(resource),
      resource_index_route(resource),
      class: "navigation__link navigation__link--#{nav_link_state(resource)}"
    ) if accessible_action?(model_from_resource(resource), :index) %>
  <% end %>

  <%# Custom (non-Administrate) admin pages: %>
  <%= link_to "Suggest videos",
              admin_video_link_suggestions_path,
              class: "navigation__link" %>
</nav>
