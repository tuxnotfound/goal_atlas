<%
  goal_title = "#{@scorer.name} #{goal_minute_label(@goal)}"
  seo_title  = "#{goal_title} — #{@scoring_team.name} vs #{@opponent_team.name}, #{@tournament.year} World Cup #{@match.stage.to_s.humanize}"
  goal_desc  = "#{@scorer.name} #{goal_minute_label(@goal)} for #{@scoring_team.name} vs #{@opponent_team.name} — " \
               "#{@match.stage.to_s.humanize}, #{@tournament.name}. Watch the highlight."
%>
<% seo_for title: seo_title, description: goal_desc %>

<div class="max-w-6xl mx-auto">

<%
  match_label = @match.scheduled? ?
                  "#{@match.home_team.name} vs #{@match.away_team.name}" :
                  "#{@match.home_team.name} #{@match.home_score}-#{@match.away_score} #{@match.away_team.name}"
%>
<%= render "shared/breadcrumbs", crumbs: [
  ["World Cups", tournaments_path],
  [@tournament.name, tournament_path(@tournament)],
  [match_label, match_path(@match)],
  [goal_title, nil]
] %>
<%= render "shared/structured_data/goal_video",
           goal: @goal, match: @match, scorer: @scorer,
           scoring_team: @scoring_team, opponent_team: @opponent_team,
           tournament: @tournament, video_links: @video_links %>

<%# === Goal hero — parchment card matching the match hero. Player card on
       the left anchors the visual; goal meta sits on the right (minute, scorer
       name, team line, score-after, type, tags). The match-summary trailer at
       the bottom links back to the match. === %>
<% map_asset = Rails.public_path.join("hero_world_map.png") %>
<% match_score = @match.home_score_after_extra_time ?
                   "#{@match.home_score_after_extra_time}–#{@match.away_score_after_extra_time}" :
                   "#{@match.home_score}–#{@match.away_score}" %>

<section class="relative overflow-hidden rounded-lg border-2 border-[#c89942]/70 shadow-xl shadow-black/30 mb-10"
         style="background:#f5e7b8;">

  <%# World map watermark %>
  <div class="absolute inset-0 pointer-events-none <%= File.exist?(map_asset) ? "opacity-20" : "text-[#1c5c3f] opacity-[0.1]" %>">
    <% if File.exist?(map_asset) %>
      <%= image_tag "/hero_world_map.png", alt: "", class: "w-full h-full object-cover" %>
    <% else %>
      <%= render "tournaments/world_map_svg" %>
    <% end %>
  </div>

  <%# Soft paper texture %>
  <div class="absolute inset-0 pointer-events-none opacity-60"
       style="background:
              radial-gradient(circle at 25% 15%, rgba(200,153,66,0.22), transparent 55%),
              radial-gradient(circle at 80% 80%, rgba(28,92,63,0.16), transparent 50%),
              radial-gradient(circle at 60% 40%, rgba(255,255,255,0.45), transparent 45%);"></div>

  <%# Decorative double-rule frame %>
  <div class="absolute inset-3 border border-[#c89942]/40 rounded pointer-events-none"></div>

  <div class="relative p-6 md:p-10">

    <%# Eyebrow: stage · tournament link, date on the right. %>
    <div class="flex items-baseline justify-between gap-3 mb-6 flex-wrap">
      <div class="text-[11px] tracking-[0.35em] uppercase text-[#c89942] font-semibold">
        <%= stage_label(@match) %>
        <span class="text-[#c89942]/60">·</span>
        <%= link_to @tournament.name, tournament_path(@tournament),
                    class: "hover:text-[#f0c870] transition" %>
      </div>
      <div class="font-serif italic text-base md:text-lg text-[#1c5c3f]">
        <%= @match.date.strftime("%-d %b %Y") %>
      </div>
    </div>

    <%# Main row: player card | goal meta. %>
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 md:gap-10">

      <%# Portrait only — taller than wide so the card bottom aligns with the
          score-after line at the foot of the meta column. The scorer name
          lives in the meta column to the right, so the panini plate would
          just duplicate it. %>
      <div class="shrink-0">
        <%= link_to player_path(@scorer), title: @scorer.name,
                    class: "inline-block transition duration-200 hover:-translate-y-0.5" do %>
          <div class="ring-4 ring-[#c89942]/75 rounded-md overflow-hidden shadow-md shadow-black/25"
               style="width: 150px;">
            <%= render "players/avatar", player: @scorer, tournament: @tournament, size: 150, height: 230, radius: "0" %>
          </div>
        <% end %>
      </div>

      <div class="flex-1 min-w-0 text-center sm:text-left">
        <%# Minute — huge serif, the visual anchor of the meta column. %>
        <div class="font-serif font-bold text-[#0a3520] tabular-nums leading-none mb-3"
             style="font-size:clamp(3rem, 7vw, 5rem); letter-spacing:-0.02em;">
          <%= goal_minute_label(@goal) %>
        </div>

        <%# Scorer name + flag. %>
        <div class="flex items-center justify-center sm:justify-start gap-3 mb-4">
          <span class="text-3xl leading-none"><%= @scoring_team.flag_emoji %></span>
          <%= link_to @scorer.name, player_path(@scorer),
                      class: "font-serif font-bold text-2xl md:text-3xl text-[#0a3520] hover:text-[#f0c870] transition leading-tight" %>
        </div>

        <%# Scoring team vs opponent. %>
        <div class="text-[11px] uppercase tracking-[0.3em] text-[#c89942] font-semibold mb-5">
          <%= link_to @scoring_team.name, team_path(@scoring_team),
                      class: "hover:text-[#f0c870] transition" %>
          <span class="text-[#c89942]/60">vs</span>
          <%= link_to @opponent_team.name, team_path(@opponent_team),
                      class: "hover:text-[#f0c870] transition" %>
        </div>

        <%# Score after goal — single data-strip in the gold/forest rhythm. %>
        <div class="flex flex-wrap justify-center sm:justify-start gap-x-6 gap-y-3 text-[11px] uppercase tracking-[0.25em] text-[#c89942] font-semibold">
          <div class="flex items-baseline gap-1.5">
            <span class="text-[#c89942]/70">Score after</span>
            <span class="text-[#1c5c3f] font-serif font-bold tabular-nums normal-case tracking-normal text-base">
              <%= @goal.score_after_goal_home %>&ndash;<%= @goal.score_after_goal_away %>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Match-summary trailer — gold-bordered shelf at the foot, links back to
      the match. Background stays transparent so the map watermark continues
      underneath. %>
  <div class="relative border-t border-[#c89942]/40">
    <div class="absolute inset-0 pointer-events-none bg-[#c89942]/10"></div>
    <%= link_to match_path(@match),
                class: "relative block px-6 md:px-10 py-4 hover:bg-[#f5e7b8] transition" do %>
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <div class="flex items-center gap-2 min-w-0">
          <span class="text-2xl leading-none"><%= @match.home_team.flag_emoji %></span>
          <span class="font-serif font-bold text-[#0a3520] truncate"><%= @match.home_team.name %></span>
        </div>
        <div class="font-serif font-bold text-[#0a3520] text-xl tabular-nums shrink-0">
          <%= match_score %>
          <% if (label = result_type_short(@match)) %>
            <span class="text-[10px] uppercase tracking-[0.25em] text-[#c89942] ml-1 font-sans align-middle"><%= label %></span>
          <% end %>
        </div>
        <div class="flex items-center gap-2 min-w-0">
          <span class="font-serif font-bold text-[#0a3520] truncate"><%= @match.away_team.name %></span>
          <span class="text-2xl leading-none"><%= @match.away_team.flag_emoji %></span>
        </div>
      </div>
      <div class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-semibold mt-2 text-center">
        <%= @match.date.strftime("%-d %b %Y") %>
        <span class="text-[#c89942]/60">·</span>
        <%= @match.stadium.name %>
      </div>
    <% end %>
  </div>
</section>

<%= render "video_links/video_links", links: @video_links, title: "Watch this goal" %>

</div>

