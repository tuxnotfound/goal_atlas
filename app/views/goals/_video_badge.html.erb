<%# Small play-circle badge marking a goal whose video link is validated, so
    users know we have a watchable clip for it. Renders nothing otherwise.
    Locals: goal (Goal); size (optional, Tailwind w/h classes, default w-4 h-4) %>
<% if goal.video_validated? %>
  <span class="shrink-0 inline-flex text-[#1c5c3f]" title="Video available" aria-label="Video available">
    <svg class="<%= local_assigns.fetch(:size, "w-4 h-4") %>" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
    </svg>
  </span>
<% end %>
