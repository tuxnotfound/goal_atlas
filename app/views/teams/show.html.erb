<% content_for :title, "#{@team.name} — Goal Atlas" %>

<%# === Team header === %>
<section class="bg-white border border-stone-200 rounded-lg p-6 mb-6">
  <div class="flex items-center gap-4 mb-2">
    <span class="text-6xl"><%= @team.flag_emoji %></span>
    <div>
      <h1 class="text-3xl font-bold tracking-tight"><%= @team.name %></h1>
      <div class="text-stone-500 text-sm mt-1">
        <%= @team.fifa_code %> · <%= @team.confederation.upcase %>
        <% if @team.active_until %>
          · Active <%= @team.active_from %>–<%= @team.active_until %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-2 gap-4 text-sm">
    <div>
      <div class="text-stone-500 text-xs uppercase tracking-wide">Goals scored</div>
      <div class="font-semibold text-lg tabular-nums"><%= @goals.size %></div>
    </div>
    <div>
      <div class="text-stone-500 text-xs uppercase tracking-wide">Matches</div>
      <div class="font-semibold text-lg tabular-nums"><%= @matches.size %></div>
    </div>
  </div>
</section>

<%# === World Cup history === %>
<% if @tournament_records.any? %>
  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-3">World Cup history</h2>
    <div class="overflow-x-auto border border-stone-200 rounded-md bg-white">
      <table class="w-full text-sm tabular-nums">
        <thead class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wide">
          <tr>
            <th class="text-left px-3 py-2">Year</th>
            <th class="text-right px-3 py-2">P</th>
            <th class="text-right px-3 py-2">W</th>
            <th class="text-right px-3 py-2">D</th>
            <th class="text-right px-3 py-2">L</th>
            <th class="text-right px-3 py-2">GF</th>
            <th class="text-right px-3 py-2">GA</th>
            <th class="text-right px-3 py-2">GD</th>
            <th class="text-left px-3 py-2">Finish</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @tournament_records.each do |r| %>
            <tr class="hover:bg-stone-50">
              <td class="px-3 py-2">
                <%= link_to r.tournament.year, tournament_path(r.tournament),
                            class: "font-medium hover:text-emerald-700" %>
              </td>
              <td class="text-right px-3 py-2"><%= r.matches_played %></td>
              <td class="text-right px-3 py-2"><%= r.wins %></td>
              <td class="text-right px-3 py-2"><%= r.draws %></td>
              <td class="text-right px-3 py-2"><%= r.losses %></td>
              <td class="text-right px-3 py-2"><%= r.goals_for %></td>
              <td class="text-right px-3 py-2"><%= r.goals_against %></td>
              <td class="text-right px-3 py-2 <%= 'text-emerald-700' if r.goal_difference.positive? %><%= 'text-rose-700' if r.goal_difference.negative? %>">
                <%= r.goal_difference.positive? ? "+#{r.goal_difference}" : r.goal_difference %>
              </td>
              <td class="px-3 py-2">
                <span class="<%= 'font-semibold text-amber-700' if r.champion? %><%= 'text-stone-500' unless r.podium? %>">
                  <%= r.finish_label %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<%# === Awards won === %>
<% if @team_awards.any? %>
  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-3">Tournament awards</h2>
    <ul class="space-y-3">
      <% @team_awards.each do |tournament, awards| %>
        <li class="bg-white border border-stone-200 rounded-md p-4">
          <div class="text-xs uppercase tracking-wide text-emerald-700 font-semibold mb-2">
            <%= link_to tournament.year, tournament_path(tournament), class: "hover:text-emerald-900" %>
          </div>
          <ul class="space-y-1 text-sm">
            <% awards.each do |a| %>
              <li class="flex items-start gap-2">
                <span class="text-stone-500 min-w-[120px]"><%= a.award_type.to_s.humanize %></span>
                <span>
                  <%= link_to a.player.name, player_path(a.player), class: "font-medium hover:text-emerald-700" %>
                  <% if a.notes.present? %>
                    <span class="text-stone-500 text-xs">· <%= a.notes %></span>
                  <% end %>
                </span>
              </li>
            <% end %>
          </ul>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<%# === Goals lane === %>
<section class="mb-8">
  <h2 class="text-lg font-semibold mb-3">Goals scored by <%= @team.name %></h2>
  <% if @goals.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% @goals.each do |g| %>
        <%= render "goals/goal_row", goal: g %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-stone-500">No goals in our dataset yet.</p>
  <% end %>
</section>

<%# === Matches lane === %>
<section class="mb-8">
  <h2 class="text-lg font-semibold mb-3">Matches</h2>
  <% if @matches.any? %>
    <ul class="divide-y divide-stone-200 border border-stone-200 rounded-md bg-white">
      <% @matches.each do |match| %>
        <li>
          <%= link_to match_path(match), class: "block p-3 hover:bg-stone-50 transition" do %>
            <div class="flex items-center justify-between gap-3">
              <span class="text-xs uppercase tracking-wide text-emerald-700 font-semibold">
                <%= stage_label(match) %>
              </span>
              <span class="text-xs text-stone-400"><%= match.date.strftime("%b %-d, %Y") %></span>
            </div>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xl"><%= match.home_team.flag_emoji %></span>
              <span class="font-medium"><%= match.home_team.name %></span>
              <span class="mx-2 font-mono tabular-nums">
                <% if match.home_score_after_extra_time %>
                  <%= match.home_score_after_extra_time %>&ndash;<%= match.away_score_after_extra_time %>
                <% else %>
                  <%= match.home_score %>&ndash;<%= match.away_score %>
                <% end %>
              </span>
              <span class="font-medium"><%= match.away_team.name %></span>
              <span class="text-xl"><%= match.away_team.flag_emoji %></span>
              <% if (label = result_type_short(match)) %>
                <span class="text-xs text-stone-500 ml-1"><%= label %></span>
              <% end %>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-stone-500">No matches in our dataset yet.</p>
  <% end %>
</section>
