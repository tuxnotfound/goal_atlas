<% content_for :title, "#{@team.name} — Goal Atlas" %>

<%# === Team header === %>
<section class="bg-white border border-stone-200 rounded-lg p-6 mb-6">
  <div class="flex items-center gap-4 mb-2">
    <span class="text-6xl"><%= @team.flag_emoji %></span>
    <div>
      <h1 class="text-3xl font-bold tracking-tight"><%= @team.name %></h1>
      <div class="text-stone-500 text-sm mt-1">
        <%= @team.fifa_code %> · <%= @team.confederation.upcase %>
        <% if @team.active_until %>
          · Active <%= @team.active_from %>–<%= @team.active_until %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-2 gap-4 text-sm">
    <div>
      <div class="text-stone-500 text-xs uppercase tracking-wide">Goals scored</div>
      <div class="font-semibold text-lg tabular-nums"><%= @goals.size %></div>
    </div>
    <div>
      <div class="text-stone-500 text-xs uppercase tracking-wide">Matches</div>
      <div class="font-semibold text-lg tabular-nums"><%= @matches.size %></div>
    </div>
  </div>
</section>

<%# === Goals lane === %>
<section class="mb-8">
  <h2 class="text-lg font-semibold mb-3">Goals scored by <%= @team.name %></h2>
  <% if @goals.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% @goals.each do |g| %>
        <%= render "goals/goal_row", goal: g %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-stone-500">No goals in our dataset yet.</p>
  <% end %>
</section>

<%# === Matches lane === %>
<section class="mb-8">
  <h2 class="text-lg font-semibold mb-3">Matches</h2>
  <% if @matches.any? %>
    <ul class="divide-y divide-stone-200 border border-stone-200 rounded-md bg-white">
      <% @matches.each do |match| %>
        <li>
          <%= link_to match_path(match), class: "block p-3 hover:bg-stone-50 transition" do %>
            <div class="flex items-center justify-between gap-3">
              <span class="text-xs uppercase tracking-wide text-emerald-700 font-semibold">
                <%= stage_label(match) %>
              </span>
              <span class="text-xs text-stone-400"><%= match.date.strftime("%b %-d, %Y") %></span>
            </div>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xl"><%= match.home_team.flag_emoji %></span>
              <span class="font-medium"><%= match.home_team.name %></span>
              <span class="mx-2 font-mono tabular-nums">
                <% if match.home_score_after_extra_time %>
                  <%= match.home_score_after_extra_time %>&ndash;<%= match.away_score_after_extra_time %>
                <% else %>
                  <%= match.home_score %>&ndash;<%= match.away_score %>
                <% end %>
              </span>
              <span class="font-medium"><%= match.away_team.name %></span>
              <span class="text-xl"><%= match.away_team.flag_emoji %></span>
              <% if (label = result_type_short(match)) %>
                <span class="text-xs text-stone-500 ml-1"><%= label %></span>
              <% end %>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-stone-500">No matches in our dataset yet.</p>
  <% end %>
</section>
