<% seo_for title: "#{@team.name} at the FIFA World Cup: All-Time Record & Goals",
           description: "#{@team.name} at the FIFA World Cup: appearances, results, players, goals, and tournament records across every edition." %>

<div class="max-w-6xl mx-auto">

<%= render "shared/breadcrumbs", crumbs: [[@team.name, nil]] %>
<%= render "shared/structured_data/team", team: @team %>

<%# === Team hero — parchment card. Flag emoji on the left anchors the visual
       (the team's equivalent of the player portrait); team name + confederation
       sit on the right. Career totals line the bottom as the trailer. === %>
<%
  map_asset       = Rails.public_path.join("hero_world_map.png")
  champion_count  = @tournament_records.count(&:champion?)
  runner_up_count = @tournament_records.count(&:runner_up?)
  total_matches   = @tournament_records.sum(&:matches_played)
  total_goals_for = @tournament_records.sum(&:goals_for)
%>

<section class="relative overflow-hidden rounded-lg border-2 border-[#c89942]/70 shadow-xl shadow-black/30 mb-10"
         style="background:#f5e7b8;">

  <%# World map watermark %>
  <div class="absolute inset-0 pointer-events-none <%= File.exist?(map_asset) ? "opacity-20" : "text-[#1c5c3f] opacity-[0.1]" %>">
    <% if File.exist?(map_asset) %>
      <%= image_tag "/hero_world_map.png", alt: "", class: "w-full h-full object-cover" %>
    <% else %>
      <%= render "tournaments/world_map_svg" %>
    <% end %>
  </div>

  <%# Soft paper texture %>
  <div class="absolute inset-0 pointer-events-none opacity-60"
       style="background:
              radial-gradient(circle at 25% 15%, rgba(200,153,66,0.22), transparent 55%),
              radial-gradient(circle at 80% 80%, rgba(28,92,63,0.16), transparent 50%),
              radial-gradient(circle at 60% 40%, rgba(255,255,255,0.45), transparent 45%);"></div>

  <%# Decorative double-rule frame %>
  <div class="absolute inset-3 border border-[#c89942]/40 rounded pointer-events-none"></div>

  <%# Trophy — anchored top-right, only champions get one (so the visual
      asymmetry on those teams' pages reads as honoured, not decorative). %>
  <% trophy_asset = Rails.public_path.join("hero_trophy.png") %>
  <% if champion_count.positive? && File.exist?(trophy_asset) %>
    <%= image_tag "/hero_trophy.png", alt: "FIFA World Cup trophy",
          class: "absolute -top-4 right-0 sm:right-4 h-[480px] w-auto pointer-events-none drop-shadow-2xl select-none" %>
  <% end %>

  <div class="relative p-6 md:p-10">

    <%# Eyebrow: confederation + FIFA code on the left, active dates on the right. %>
    <div class="flex items-baseline justify-between gap-3 mb-6 flex-wrap">
      <div class="text-[11px] tracking-[0.35em] uppercase text-[#c89942] font-semibold">
        <%= @team.confederation.upcase %>
        <% if @team.fifa_code.present? %>
          <span class="text-[#c89942]/60">·</span>
          <%= @team.fifa_code %>
        <% end %>
      </div>
      <% if @team.active_from || @team.active_until %>
        <div class="font-serif italic text-base md:text-lg text-[#1c5c3f]">
          Active
          <%= @team.active_from || "?" %>&ndash;<%= @team.active_until || "present" %>
        </div>
      <% end %>
    </div>

    <%# Main row: flag emoji | name. %>
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 md:gap-10">

      <div class="shrink-0 leading-none select-none"
           style="font-size:clamp(8rem, 18vw, 12rem);">
        <%= @team.flag_emoji %>
      </div>

      <div class="flex-1 min-w-0 text-center sm:text-left">
        <%# Champion star crown + name share an inline-block wrapper so the
            stars row centers above the team-name text rather than against the
            whole meta column. Wrapper itself stays left-aligned at sm+. %>
        <div class="inline-block mb-4">
          <% if champion_count.positive? %>
            <div class="flex justify-center gap-1 mb-2 text-[#c89942] leading-none"
                 style="font-size:clamp(1rem, 1.75vw, 1.5rem);"
                 title="<%= pluralize(champion_count, "World Cup") %> won">
              <% champion_count.times do %><span>★</span><% end %>
            </div>
          <% end %>

          <h1 class="font-serif font-bold text-[#0a3520] leading-none"
              style="font-size:clamp(2.5rem, 6vw, 4.5rem); letter-spacing:-0.02em;">
            <%= @team.name %>
          </h1>
        </div>

        <% if champion_count.positive? || runner_up_count.positive? %>
          <div class="flex flex-wrap justify-center sm:justify-start items-center gap-x-4 gap-y-1 text-[11px] uppercase tracking-[0.3em] text-[#c89942] font-semibold">
            <% if champion_count.positive? %>
              <span class="text-[#1c5c3f]"><%= pluralize(champion_count, "time") %> World Cup champion</span>
            <% end %>
            <% if runner_up_count.positive? %>
              <span class="text-[#c89942]"><%= pluralize(runner_up_count, "time") %> runner-up</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Career totals trailer. %>
  <div class="relative border-t border-[#c89942]/40">
    <div class="absolute inset-0 pointer-events-none bg-[#c89942]/10"></div>
    <div class="relative px-6 md:px-10 py-5 flex flex-wrap justify-center gap-x-10 gap-y-4">
      <div class="text-center">
        <div class="font-serif font-bold text-[#0a3520] tabular-nums leading-none text-3xl md:text-4xl">
          <%= @tournament_records.size %>
        </div>
        <div class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-bold mt-1">
          <%= @tournament_records.size == 1 ? "Tournament" : "Tournaments" %>
        </div>
      </div>

      <div class="text-center">
        <div class="font-serif font-bold text-[#0a3520] tabular-nums leading-none text-3xl md:text-4xl">
          <%= total_matches %>
        </div>
        <div class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-bold mt-1">
          Matches
        </div>
      </div>

      <div class="text-center">
        <div class="font-serif font-bold text-[#0a3520] tabular-nums leading-none text-3xl md:text-4xl">
          <%= total_goals_for %>
        </div>
        <div class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-bold mt-1">
          <%= total_goals_for == 1 ? "Goal scored" : "Goals scored" %>
        </div>
      </div>
    </div>
  </div>
</section>

<%# === All-time top scorers podium — same silver/gold/bronze step layout as
       the golden boot podium on the tournament page, but counting every goal
       the player has ever scored for this team across all World Cups. === %>
<% if @top_scorers.any? %>
  <section class="mb-12">
    <h2 class="font-serif text-2xl text-[#f0c870] mb-1 text-center">All-time top scorers</h2>
    <p class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-semibold text-center mb-8">
      Every <%= @team.name %> World Cup goal
    </p>

    <% podium_slots = [
         { rank: 2, scorer: @top_scorers[1], card_size: 130, step_w: "w-[130px]",
           step_h: "h-32 sm:h-40", grad: "linear-gradient(180deg, #e5d4a3, #b9a378)",
           border: "border-[#7a6438]", num_color: "text-[#0a3520]", label_color: "text-[#0a3520]/70",
           num_size: "text-4xl sm:text-5xl" },
         { rank: 1, scorer: @top_scorers[0], card_size: 170, step_w: "w-[170px]",
           step_h: "h-44 sm:h-56", grad: "linear-gradient(180deg, #f0c870, #c89942)",
           border: "border-[#7a4b1a]", num_color: "text-[#0a3520]", label_color: "text-[#0a3520]/80",
           num_size: "text-5xl sm:text-6xl" },
         { rank: 3, scorer: @top_scorers[2], card_size: 130, step_w: "w-[130px]",
           step_h: "h-28 sm:h-32", grad: "linear-gradient(180deg, #cd8b4a, #8b4513)",
           border: "border-[#5a3614]", num_color: "text-[#fef0c8]", label_color: "text-[#fef0c8]/80",
           num_size: "text-4xl sm:text-5xl" }
       ] %>

    <div class="flex items-end justify-center gap-4 sm:gap-8 max-w-4xl mx-auto">
      <% podium_slots.each do |slot| %>
        <% scorer = slot[:scorer] %>
        <% next unless scorer %>
        <% is_winner = slot[:rank] == 1 %>

        <div class="flex flex-col items-center">
          <% if is_winner %>
            <div class="text-2xl mb-1 text-[#c89942] leading-none">★</div>
          <% end %>

          <%= render "players/card", player: scorer, size: slot[:card_size] %>

          <div class="<%= slot[:step_w] %> <%= slot[:step_h] %> mt-2 rounded-t-md flex flex-col items-center justify-center border-2 border-b-0 <%= slot[:border] %> shadow-md shadow-black/25"
               style="background: <%= slot[:grad] %>;">
            <div class="font-serif <%= slot[:num_size] %> font-bold leading-none <%= slot[:num_color] %>">
              <%= scorer.goals_count %>
            </div>
            <div class="text-[10px] uppercase tracking-widest mt-2 font-semibold <%= slot[:label_color] %>">
              <%= scorer.goals_count == 1 ? "Goal" : "Goals" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<%# === World Cup history + Tournament awards — paired side-by-side on lg+
       screens; either one falls back to its own row when its sibling is
       missing. === %>
<%
  has_history    = @tournament_records.any?
  has_awards     = @team_awards.any?
  paired         = has_history && has_awards
  history_cols   = paired ? "" : "max-w-3xl mx-auto"
  awards_cols    = paired ? "" : "max-w-3xl mx-auto"
%>

<% if has_history || has_awards %>
  <div class="<%= paired ? "grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10 items-start" : "" %>">
<% end %>

<% if has_history %>
  <% stat_cols = [
       { key: :p,   w: "w-4",  label: "P"   },
       { key: :w,   w: "w-4",  label: "W"   },
       { key: :d,   w: "w-4",  label: "D"   },
       { key: :l,   w: "w-4",  label: "L"   },
       { key: :gd,  w: "w-6",  label: "GD"  }
     ] %>
  <section class="<%= "mb-10" unless paired %> <%= history_cols %>">
    <h2 class="font-serif text-xl text-[#f0c870] mb-3 text-center">World Cup history</h2>

    <div class="rounded border border-[#c89942]/70 shadow-md shadow-black/20 overflow-hidden"
         style="background:#fdf6dc;">

      <div class="px-3 py-2 border-b border-[#c89942]/40 flex items-center justify-between gap-2"
           style="background:#f5e7b8;">
        <span class="font-serif text-base font-bold text-[#0a3520]">Year</span>
        <span class="flex items-center gap-1.5 text-[9px] uppercase text-[#c89942] font-semibold">
          <% stat_cols.each do |col| %>
            <span class="font-mono <%= col[:w] %> text-right"><%= col[:label] %></span>
          <% end %>
        </span>
      </div>

      <% @tournament_records.sort_by { |r| -r.tournament.year }.each do |r| %>
        <% gd = r.goal_difference %>
        <%= link_to tournament_path(r.tournament),
                    class: "flex items-center justify-between gap-2 px-3 py-1.5 border-b border-[#c89942]/15 last:border-b-0 hover:bg-[#f5e7b8] transition text-[#0a3520]" do %>
          <span class="flex items-center gap-2 min-w-0">
            <span class="font-serif font-bold tabular-nums shrink-0"><%= r.tournament.year %></span>
            <% if r.champion? %>
              <span class="text-[#c89942] text-xs leading-none shrink-0" title="Champions">★</span>
            <% end %>
            <span class="text-[10px] uppercase tracking-[0.25em] <%= r.podium? ? "text-[#1c5c3f]" : "text-[#c89942]/85" %> font-semibold truncate">
              <%= r.finish_label %>
            </span>
          </span>
          <span class="flex items-center gap-1.5 shrink-0">
            <% stat_cols.each do |col| %>
              <span class="font-mono text-[11px] tabular-nums <%= col[:w] %> text-right">
                <%= case col[:key]
                    when :p  then r.matches_played
                    when :w  then r.wins
                    when :d  then r.draws
                    when :l  then r.losses
                    when :gd then (gd > 0 ? "+#{gd}" : gd)
                    end %>
              </span>
            <% end %>
          </span>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<% if has_awards %>
  <section class="<%= "mb-10" unless paired %> <%= awards_cols %>">
    <h2 class="font-serif text-xl text-[#f0c870] mb-3 text-center">Tournament awards</h2>

    <div class="rounded border border-[#c89942]/70 shadow-md shadow-black/20 overflow-hidden"
         style="background:#fdf6dc;">
      <% @team_awards.each_with_index do |(tournament, awards), idx| %>
        <div class="<%= "border-t border-[#c89942]/20" unless idx.zero? %>">
          <div class="px-3 py-2 flex items-baseline justify-between gap-2"
               style="background:#f5e7b8;">
            <%= link_to tournament_path(tournament),
                        class: "font-serif text-base font-bold text-[#0a3520] hover:text-[#1c5c3f] transition" do %>
              <%= tournament.year %>
            <% end %>
            <span class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-semibold">
              <%= pluralize(awards.size, "award") %>
            </span>
          </div>
          <div style="background:#f9efce;">
            <% awards.each_with_index do |a, i| %>
              <div class="flex items-center gap-3 px-3 py-2 <%= "border-t border-[#c89942]/15" unless i.zero? %>">
                <span class="text-[#c89942] shrink-0">★</span>
                <span class="text-[10px] uppercase tracking-[0.25em] text-[#1c5c3f] font-semibold shrink-0 min-w-[110px]">
                  <%= a.award_type.to_s.humanize %>
                </span>
                <%= link_to player_path(a.player),
                            class: "font-serif font-bold text-[#0a3520] hover:text-[#f0c870] transition truncate" do %>
                  <%= a.player.name %>
                <% end %>
                <% if a.notes.present? %>
                  <span class="text-[10px] uppercase tracking-[0.2em] text-[#c89942]/80 truncate">
                    · <%= a.notes %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

  <% if has_history || has_awards %>
    </div>
  <% end %>

<%# === Goals scored / Matches — a single tabbed section so the two share
       vertical space. Each panel keeps its own goal-filter instance so the
       tournament-year pills only apply within the active tab. === %>
<section class="mb-10" data-controller="tabs">
  <%# Tab bar — same gold pill rhythm as the filter pills but bigger and bolder. %>
  <div class="flex justify-center gap-2 mb-6">
    <button type="button"
            data-tabs-target="tab"
            data-panel="goals"
            data-active="true"
            data-action="click->tabs#switch"
            class="px-5 py-2 rounded-full border font-serif text-lg tracking-tight transition cursor-pointer
                   border-[#c89942]/45 text-[#c89942] hover:border-[#f0c870]
                   data-[active=true]:bg-[#f0c870] data-[active=true]:text-[#0a3520] data-[active=true]:border-[#f0c870] data-[active=true]:shadow-md data-[active=true]:shadow-black/30 data-[active=true]:font-bold">
      Goals scored
    </button>
    <button type="button"
            data-tabs-target="tab"
            data-panel="matches"
            data-active="false"
            data-action="click->tabs#switch"
            class="px-5 py-2 rounded-full border font-serif text-lg tracking-tight transition cursor-pointer
                   border-[#c89942]/45 text-[#c89942] hover:border-[#f0c870]
                   data-[active=true]:bg-[#f0c870] data-[active=true]:text-[#0a3520] data-[active=true]:border-[#f0c870] data-[active=true]:shadow-md data-[active=true]:shadow-black/30 data-[active=true]:font-bold">
      Matches
    </button>
  </div>

  <%# Goals panel %>
  <div data-tabs-target="panel" data-panel="goals" data-controller="goal-filter">
    <% if @goals.any? %>
      <% years_with_goals = @goals.map { |g| g.match.tournament.year }.uniq.sort.reverse %>

      <% if years_with_goals.size > 1 %>
        <%= render "shared/year_filter", years: years_with_goals %>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% @goals.each do |g| %>
          <div data-goal-filter-target="entry" data-year="<%= g.match.tournament.year %>">
            <%= render "goals/goal_row", goal: g %>
          </div>
        <% end %>
      </div>

      <p data-goal-filter-target="empty"
         class="hidden text-sm text-[#c89942] text-center mt-4 uppercase tracking-[0.25em] font-semibold">
        No goals in this tournament
      </p>
    <% else %>
      <p class="text-sm text-[#c89942] text-center uppercase tracking-[0.25em] font-semibold">
        No goals in our dataset yet
      </p>
    <% end %>
  </div>

  <%# Matches panel %>
  <div data-tabs-target="panel" data-panel="matches" data-controller="goal-filter" class="hidden">
    <% if @matches.any? %>
      <% match_years = @matches.map { |m| m.tournament.year }.uniq.sort.reverse %>

      <% if match_years.size > 1 %>
        <%= render "shared/year_filter", years: match_years %>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% @matches.each do |match| %>
          <div data-goal-filter-target="entry" data-year="<%= match.tournament.year %>">
            <%= render "matches/card", match: match %>
          </div>
        <% end %>
      </div>

      <p data-goal-filter-target="empty"
         class="hidden text-sm text-[#c89942] text-center mt-4 uppercase tracking-[0.25em] font-semibold">
        No matches in this tournament
      </p>
    <% else %>
      <p class="text-sm text-[#c89942] text-center uppercase tracking-[0.25em] font-semibold">
        No matches in our dataset yet
      </p>
    <% end %>
  </div>
</section>

</div>
