<%#
  Emits a schema.org SportsEvent for the match into <head> as JSON-LD.
  Pass `match:` (Match instance).
%>
<%
  m = match
  name = m.scheduled? ?
           "#{m.home_team.name} vs #{m.away_team.name}" :
           "#{m.home_team.name} #{m.home_score}-#{m.away_score} #{m.away_team.name}"
  data = {
    "@context": "https://schema.org",
    "@type": "SportsEvent",
    "name": name,
    "url": match_url(m),
    "sport": "Soccer",
    "startDate": m.date.iso8601,
    "eventStatus": m.scheduled? ? "https://schema.org/EventScheduled" : "https://schema.org/EventCompleted",
    "competitor": [
      { "@type": "SportsTeam", "name": m.home_team.name },
      { "@type": "SportsTeam", "name": m.away_team.name }
    ],
    "homeTeam": { "@type": "SportsTeam", "name": m.home_team.name },
    "awayTeam": { "@type": "SportsTeam", "name": m.away_team.name }
  }
  if m.tournament
    data["superEvent"] = {
      "@type": "SportsEvent",
      "name": m.tournament.name,
      "url": tournament_url(m.tournament)
    }
  end
  if m.stadium
    data["location"] = {
      "@type": "Place",
      "name": m.stadium.name,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": m.stadium.city,
        "addressCountry": m.stadium.country_code.presence || m.stadium.country
      }.compact
    }
  end
%>
<% content_for :head do %>
<script type="application/ld+json"><%= raw data.to_json %></script>
<% end %>
