<%#
  Renders a player's portrait — tournament-tagged when a tournament is given,
  default otherwise. Falls back to a colored initials disc when no image exists.

  Locals:
    player:     Player (required)
    tournament: Tournament|nil (optional, picks tournament-tagged image when set)
    size:       Integer pixels (default 40)
    rounded:    Boolean (default true — render as circle)
%>
<% size       ||= 40 %>
<% tournament ||= nil %>
<% rounded     = local_assigns.fetch(:rounded, true) %>
<% radius      = rounded ? "9999px" : "6px" %>
<% image       = player.image_for(tournament) %>

<% if image %>
  <%= image_tag image.thumbnail(width: size * 2),
        alt: player.name,
        loading: "lazy",
        title: image.attribution_line,
        style: "width: #{size}px; height: #{size}px; object-fit: cover; border-radius: #{radius}; background: #f5f5f4;" %>
<% else %>
  <span
    aria-label="<%= player.name %>"
    style="display: inline-flex; align-items: center; justify-content: center;
           width: #{size}px; height: #{size}px; border-radius: #{radius};
           background: #e7e5e4; color: #57534e;
           font-weight: 600; font-size: #{(size * 0.38).round}px;
           letter-spacing: 0.01em; user-select: none;">
    <%= avatar_initials(player.name) %>
  </span>
<% end %>
