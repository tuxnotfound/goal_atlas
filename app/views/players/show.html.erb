<% content_for :title, "#{@player.name} — The Goal Atlas" %>

<%# === Player header === %>
<section class="bg-white border border-stone-200 rounded-lg p-6 mb-6">
  <div class="flex items-start gap-5">
    <%= render "players/avatar", player: @player, size: 120 %>

    <div class="flex-1">
      <h1 class="text-3xl font-bold tracking-tight mb-2"><%= @player.name %></h1>

      <div class="text-stone-500 text-sm space-y-1">
        <% if @player.nationality_team %>
          <div>
            <%= @player.nationality_team.flag_emoji %>
            <%= link_to @player.nationality_team.name, team_path(@player.nationality_team),
                        class: "hover:text-emerald-700 transition" %>
          </div>
        <% end %>
        <% if @player.position %>
          <div><%= @player.position.humanize %></div>
        <% end %>
        <% if @player.birth_date %>
          <div>Born <%= @player.birth_date.strftime("%B %-d, %Y") %></div>
        <% end %>
        <% if (img = @player.default_image)&.attribution_line %>
          <div class="text-xs text-stone-400 pt-1">
            Photo:
            <% if img.source_url.present? %>
              <%= link_to img.attribution_line, img.source_url,
                          target: "_blank", rel: "noopener",
                          class: "hover:text-stone-600" %>
            <% else %>
              <%= img.attribution_line %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
    <div>
      <div class="text-stone-500 text-xs uppercase tracking-wide">Goals</div>
      <div class="font-semibold text-lg tabular-nums"><%= @goals.size %></div>
    </div>
    <% if @shootout_totals[:taken].positive? %>
      <div>
        <div class="text-stone-500 text-xs uppercase tracking-wide">Shootout kicks</div>
        <div class="font-semibold text-lg tabular-nums">
          <%= @shootout_totals[:scored] %>/<%= @shootout_totals[:taken] %>
        </div>
      </div>
    <% end %>
    <% if @tournament_records.any? %>
      <div>
        <div class="text-stone-500 text-xs uppercase tracking-wide">Tournaments</div>
        <div class="font-semibold text-lg tabular-nums"><%= @tournament_records.size %></div>
      </div>
    <% end %>
  </div>
</section>

<%# === World Cup history === %>
<% if @tournament_records.any? %>
  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-3">World Cup history</h2>
    <div class="overflow-x-auto border border-stone-200 rounded-md bg-white">
      <table class="w-full text-sm tabular-nums">
        <thead class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wide">
          <tr>
            <th class="text-left px-3 py-2">Year</th>
            <th class="text-right px-3 py-2">Goals</th>
            <th class="text-right px-3 py-2">Assists</th>
            <th class="text-right px-3 py-2">Shootouts</th>
            <th class="text-left px-3 py-2">Awards</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @tournament_records.each do |r| %>
            <tr class="hover:bg-stone-50">
              <td class="px-3 py-2">
                <%= link_to r.tournament.year, tournament_path(r.tournament),
                            class: "font-medium hover:text-emerald-700" %>
              </td>
              <td class="text-right px-3 py-2"><%= r.goals_count.positive? ? r.goals_count : "—" %></td>
              <td class="text-right px-3 py-2"><%= r.assists_count.positive? ? r.assists_count : "—" %></td>
              <td class="text-right px-3 py-2">
                <% if r.shootout_kicks_count.positive? %>
                  <%= r.shootout_kicks_scored %>/<%= r.shootout_kicks_count %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="px-3 py-2">
                <% if r.has_award? %>
                  <ul class="space-y-0.5">
                    <% r.awards.each do |a| %>
                      <li class="text-amber-700">
                        <%= a.award_type.to_s.humanize %><%
                        %><% if a.notes.present? %>
                          <span class="text-stone-500 text-xs">· <%= a.notes %></span>
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                <% else %>
                  <span class="text-stone-300">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<%# === Goal type breakdown === %>
<% if @goal_type_breakdown.any? && @goals.size > 1 %>
  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-3">Goal type breakdown</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <% Goal::GOAL_TYPES.keys.each do |type| %>
        <% count = @goal_type_breakdown[type] || 0 %>
        <div class="bg-white border border-stone-200 rounded-md p-3">
          <div class="text-stone-500 text-xs uppercase tracking-wide"><%= type.to_s.humanize %></div>
          <div class="font-semibold text-lg tabular-nums <%= "text-stone-300" if count.zero? %>"><%= count %></div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<%# === Goals lane === %>
<section class="mb-8">
  <h2 class="text-lg font-semibold mb-3">Goals scored by <%= @player.name %></h2>
  <% if @goals.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% @goals.each do |g| %>
        <%= render "goals/goal_row", goal: g %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-stone-500">No goals in our dataset yet.</p>
  <% end %>
</section>
