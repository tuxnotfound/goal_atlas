<%
  score_segment = @match.scheduled? ? "vs" : "#{@match.home_score}-#{@match.away_score}"
  match_title   = "#{@match.home_label} #{score_segment} #{@match.away_label}"
  stage_label   = @match.stage.to_s.humanize
  date_label    = @match.date&.strftime("%-d %b %Y")
  tournament_label = @match.tournament&.name
  seo_title = "#{match_title}: #{@match.tournament.year} World Cup #{stage_label}"
  match_desc = [
    "#{match_title} — #{stage_label}",
    date_label,
    tournament_label
  ].compact.reject(&:empty?).join(" · ") + ". Goals, scorers, lineups, and video highlights."
%>
<% seo_for title: seo_title, description: match_desc %>

<div class="max-w-6xl mx-auto">

<%= render "shared/breadcrumbs", crumbs: [
  ["World Cups", tournaments_path],
  [@match.tournament.name, tournament_path(@match.tournament)],
  [match_title, nil]
] %>
<%= render "shared/structured_data/match", match: @match %>

<%# === Match hero — parchment card mirroring the tournament hero: gold border,
       world map watermark, soft paper texture, decorative inner frame. The score
       is the visual anchor; team names flank it, stage/date/venue trail beneath
       in serif eyebrows. === %>
<% home_winner = @match.winner_team_id && @match.winner_team_id == @match.home_team_id %>
<% away_winner = @match.winner_team_id && @match.winner_team_id == @match.away_team_id %>
<% map_asset   = Rails.public_path.join("hero_world_map.png") %>

<section class="relative overflow-hidden rounded-lg border-2 border-[#c89942]/70 shadow-xl shadow-black/30 mb-10"
         style="background:#f5e7b8;">

  <%# World map watermark %>
  <div class="absolute inset-0 pointer-events-none <%= File.exist?(map_asset) ? "opacity-20" : "text-[#1c5c3f] opacity-[0.1]" %>">
    <% if File.exist?(map_asset) %>
      <%= image_tag "/hero_world_map.png", alt: "", class: "w-full h-full object-cover" %>
    <% else %>
      <%= render "tournaments/world_map_svg" %>
    <% end %>
  </div>

  <%# Soft paper texture %>
  <div class="absolute inset-0 pointer-events-none opacity-60"
       style="background:
              radial-gradient(circle at 25% 15%, rgba(200,153,66,0.22), transparent 55%),
              radial-gradient(circle at 80% 80%, rgba(28,92,63,0.16), transparent 50%),
              radial-gradient(circle at 60% 40%, rgba(255,255,255,0.45), transparent 45%);"></div>

  <%# Decorative double-rule frame %>
  <div class="absolute inset-3 border border-[#c89942]/40 rounded pointer-events-none"></div>

  <div class="relative p-6 md:p-10">

    <%# Eyebrow: stage · tournament link, date on the right. %>
    <div class="flex items-baseline justify-between gap-3 mb-6 flex-wrap">
      <div class="text-[11px] tracking-[0.35em] uppercase text-[#c89942] font-semibold">
        <%= stage_label(@match) %>
        <span class="text-[#c89942]/60">·</span>
        <%= link_to @match.tournament.name, tournament_path(@match.tournament),
                    class: "hover:text-[#f0c870] transition" %>
      </div>
      <div class="font-serif italic text-base md:text-lg text-[#1c5c3f]">
        <%= @match.date.strftime("%-d %b %Y") %>
      </div>
    </div>

    <%# Scoreline: flag/name | score | flag/name. %>
    <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4 md:gap-10">

      <div class="text-right min-w-0">
        <div class="text-5xl md:text-6xl leading-none mb-3"><%= @match.home_team&.flag_emoji || "⚪" %></div>
        <% if @match.home_team %>
          <%= link_to team_path(@match.home_team),
                      class: "block font-serif font-bold text-xl md:text-2xl leading-tight hover:text-[#f0c870] transition #{home_winner ? "text-[#0a3520]" : "text-[#6e7d6e]"}" do %>
            <%= @match.home_team.name %>
          <% end %>
        <% else %>
          <span class="block font-serif font-bold italic text-lg md:text-xl leading-tight text-[#6e7d6e]"><%= @match.home_label %></span>
        <% end %>
        <% if home_winner %>
          <div class="text-[9px] uppercase tracking-[0.35em] text-[#c89942] font-bold mt-2 flex items-center justify-end gap-1.5">
            <span>Winner</span><span>★</span>
          </div>
        <% end %>
      </div>

      <div class="text-center">
        <div class="font-serif font-bold text-[#0a3520] tabular-nums leading-none"
             style="font-size:clamp(3.75rem, 10vw, 6.5rem); letter-spacing:-0.02em;">
          <% if @match.scheduled? %>
            <span class="text-[#c89942]">&ndash;</span>
          <% else %>
            <%= @match.home_score %><span class="text-[#c89942]">&ndash;</span><%= @match.away_score %>
          <% end %>
        </div>
        <% if @match.home_score_after_extra_time %>
          <div class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-bold mt-3 tabular-nums">
            AET&nbsp;<%= @match.home_score_after_extra_time %>&ndash;<%= @match.away_score_after_extra_time %>
          </div>
        <% end %>
        <% if @match.home_penalties %>
          <div class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-bold mt-1 tabular-nums">
            Pens&nbsp;<%= @match.home_penalties %>&ndash;<%= @match.away_penalties %>
          </div>
        <% end %>
      </div>

      <div class="text-left min-w-0">
        <div class="text-5xl md:text-6xl leading-none mb-3"><%= @match.away_team&.flag_emoji || "⚪" %></div>
        <% if @match.away_team %>
          <%= link_to team_path(@match.away_team),
                      class: "block font-serif font-bold text-xl md:text-2xl leading-tight hover:text-[#f0c870] transition #{away_winner ? "text-[#0a3520]" : "text-[#6e7d6e]"}" do %>
            <%= @match.away_team.name %>
          <% end %>
        <% else %>
          <span class="block font-serif font-bold italic text-lg md:text-xl leading-tight text-[#6e7d6e]"><%= @match.away_label %></span>
        <% end %>
        <% if away_winner %>
          <div class="text-[9px] uppercase tracking-[0.35em] text-[#c89942] font-bold mt-2 flex items-center gap-1.5">
            <span>★</span><span>Winner</span>
          </div>
        <% end %>
      </div>
    </div>

    <%# Venue + attendance trailer — flex row that wraps under small widths. %>
    <div class="mt-8 pt-5 border-t border-[#c89942]/30 flex flex-wrap justify-center gap-x-8 gap-y-3 text-[11px] uppercase tracking-[0.25em] text-[#c89942] font-semibold">
      <div class="flex items-baseline gap-1.5">
        <span class="text-[#c89942]/70">Stadium</span>
        <span class="text-[#1c5c3f] font-serif font-bold normal-case tracking-normal text-sm"><%= @match.stadium.name %></span>
      </div>
      <div class="flex items-baseline gap-1.5">
        <span class="text-[#c89942]/70">City</span>
        <span class="text-[#1c5c3f] font-serif font-bold normal-case tracking-normal text-sm"><%= @match.stadium.city %></span>
      </div>
      <% if @match.attendance %>
        <div class="flex items-baseline gap-1.5">
          <span class="text-[#c89942]/70">Attendance</span>
          <span class="text-[#1c5c3f] font-serif font-bold tabular-nums normal-case tracking-normal text-sm"><%= number_with_delimiter(@match.attendance) %></span>
        </div>
      <% end %>
    </div>
  </div>

  <%# Goals timeline — shelf at the foot of the hero, mirroring the group-card
      fixtures list. Background stays transparent so the world-map watermark
      continues underneath; a faint gold tint overlay marks it as a distinct
      shelf without hiding the map. Each row links to the goal page so deeper
      detail (highlight clip, tags) is one click away. %>
  <% if @goals.any? %>
    <div class="relative border-t border-[#c89942]/40">
      <div class="absolute inset-0 pointer-events-none bg-[#c89942]/10"></div>
      <div class="relative px-6 md:px-10 py-4">
        <div class="text-[10px] uppercase tracking-[0.35em] text-[#c89942] font-semibold text-center mb-3">
          Goals
        </div>
        <%# Desktop rows mirror the hero scoreline: home side | running score |
            away side on a 1fr_auto_1fr grid, the score centred under the final
            score above. On phones that grid squeezes names to nothing, so
            mobile gets a stacked two-line row instead: minute · score · flag up
            top, the full (untruncated) scorer name beneath. %>
        <ol>
          <% @goals.each do |goal| %>
            <% home_scored = goal.scoring_team_id == @match.home_team_id %>
            <li>
              <%= link_to goal_path(goal),
                          class: "block py-2 border-t border-[#c89942]/15 first:border-t-0 hover:bg-[#f5e7b8] transition rounded" do %>

                <%# Mobile (< sm): two lines. Line 1 = minute (top-left) · score
                    (centred) · flag on the scoring team's side. Line 2 = the full
                    scorer name, anchored to that same side so it reads under the
                    team that scored, exactly like the desktop grid. %>
                <div class="sm:hidden px-1">
                  <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3">
                    <span class="flex items-center gap-2 justify-start font-mono text-[11px] tabular-nums text-[#c89942]">
                      <%= goal_minute_label(goal) %>
                      <% if home_scored %>
                        <span class="text-lg leading-none"><%= goal.scoring_team.flag_emoji %></span>
                      <% end %>
                    </span>
                    <span class="font-mono text-xs tabular-nums font-bold text-[#1c5c3f] text-center">
                      <%= goal.score_after_goal_home %>&ndash;<%= goal.score_after_goal_away %>
                    </span>
                    <span class="flex items-center justify-end">
                      <% unless home_scored %>
                        <span class="text-lg leading-none"><%= goal.scoring_team.flag_emoji %></span>
                      <% end %>
                    </span>
                  </div>
                  <div class="mt-1 flex items-center flex-wrap gap-x-2 gap-y-1 <%= home_scored ? "justify-start text-left" : "justify-end text-right" %>">
                    <span class="font-serif font-bold text-[#0a3520] text-sm leading-tight">
                      <%= goal.player.name %>
                    </span>
                    <%= render "goals/own_goal_badge", goal: goal %>
                    <%= render "goals/video_badge", goal: goal %>
                  </div>
                </div>

                <%# Desktop (>= sm): single-line hero-style grid. The minute is
                    pinned far left (absolute) so it never nudges the centred
                    score; scorer + flag hang on the credited team's side. %>
                <div class="relative hidden sm:grid grid-cols-[1fr_auto_1fr] items-center gap-4 md:gap-10">
                  <span class="absolute left-0 inset-y-0 w-12 flex items-center justify-end font-mono text-[11px] tabular-nums text-[#c89942]">
                    <%= goal_minute_label(goal) %>
                  </span>

                  <span class="min-w-0 flex items-center justify-end gap-2 pl-14">
                    <% if home_scored %>
                      <span class="font-serif font-bold text-[#0a3520] text-sm truncate leading-tight">
                        <%= goal.player.name %>
                      </span>
                      <%= render "goals/own_goal_badge", goal: goal %>
                      <%= render "goals/video_badge", goal: goal %>
                      <span class="text-lg leading-none shrink-0"><%= goal.scoring_team.flag_emoji %></span>
                    <% end %>
                  </span>

                  <span class="font-mono text-xs tabular-nums font-bold text-[#1c5c3f] text-center shrink-0">
                    <%= goal.score_after_goal_home %>&ndash;<%= goal.score_after_goal_away %>
                  </span>

                  <span class="min-w-0 flex items-center justify-start gap-2 pr-2">
                    <% unless home_scored %>
                      <span class="text-lg leading-none shrink-0"><%= goal.scoring_team.flag_emoji %></span>
                      <%= render "goals/own_goal_badge", goal: goal %>
                      <%= render "goals/video_badge", goal: goal %>
                      <span class="font-serif font-bold text-[#0a3520] text-sm truncate leading-tight">
                        <%= goal.player.name %>
                      </span>
                    <% end %>
                  </span>
                </div>
              <% end %>
            </li>
          <% end %>
        </ol>
      </div>
    </div>
  <% end %>

  <%# Penalty shootout — second parchment shelf, only when the match went to
      pens. Same transparent-with-gold-tint treatment as the goals shelf so
      the map watermark continues underneath. %>
  <% if @shootout_kicks.any? %>
    <%# Pair each round's two kicks onto one row — home kicker on the left,
        away kicker on the right, names anchored to their team's side like the
        scoreline above. A round may hold a single kick (sudden death / the
        shootout ending mid-round), in which case only that side renders. %>
    <% home_kicks = @shootout_kicks.select { |k| k.team_id == @match.home_team_id } %>
    <% away_kicks = @shootout_kicks.select { |k| k.team_id == @match.away_team_id } %>
    <% round_count = [home_kicks.size, away_kicks.size].max %>
    <div class="relative border-t border-[#c89942]/40">
      <div class="absolute inset-0 pointer-events-none bg-[#c89942]/10"></div>
      <div class="relative px-6 md:px-10 py-4">
        <div class="text-[10px] uppercase tracking-[0.35em] text-[#c89942] font-semibold text-center mb-3">
          Penalty shootout
        </div>
        <ol class="max-w-xl mx-auto">
          <% (0...round_count).each do |i| %>
            <% home = home_kicks[i]; away = away_kicks[i] %>
            <li class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 sm:gap-4 py-2 border-t border-[#c89942]/15 first:border-t-0">
              <%# Home kicker — name then verdict, hugging the centre %>
              <span class="min-w-0 flex items-center justify-end gap-2">
                <% if home %>
                  <span class="min-w-0 text-right">
                    <span class="block font-serif font-bold text-[#0a3520] text-sm truncate leading-tight"><%= home.player.name %></span>
                    <% if home.notes.present? %>
                      <span class="block text-[9px] uppercase tracking-[0.15em] text-[#c89942]/80 truncate leading-tight"><%= home.notes %></span>
                    <% end %>
                  </span>
                  <%= render "matches/shootout_verdict", kick: home %>
                <% end %>
              </span>
              <%# Round number %>
              <span class="font-mono text-[11px] tabular-nums text-[#c89942] text-center shrink-0 w-5"><%= i + 1 %></span>
              <%# Away kicker — verdict then name %>
              <span class="min-w-0 flex items-center justify-start gap-2">
                <% if away %>
                  <%= render "matches/shootout_verdict", kick: away %>
                  <span class="min-w-0 text-left">
                    <span class="block font-serif font-bold text-[#0a3520] text-sm truncate leading-tight"><%= away.player.name %></span>
                    <% if away.notes.present? %>
                      <span class="block text-[9px] uppercase tracking-[0.15em] text-[#c89942]/80 truncate leading-tight"><%= away.notes %></span>
                    <% end %>
                  </span>
                <% end %>
              </span>
            </li>
          <% end %>
        </ol>
      </div>
    </div>
  <% end %>
</section>

<%= render "shared/structured_data/match_faq", match: @match %>

<%= render "video_links/video_links", links: @video_links %>

</div>

