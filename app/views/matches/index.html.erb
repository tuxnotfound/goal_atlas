<% seo_for title: "Matches",
           description: "Browse every FIFA World Cup match — group stage, knockout rounds, finals — with results, goals, and highlight links." %>

<div class="max-w-6xl mx-auto" data-controller="goal-filter">

  <div class="mb-8 text-center">
    <h1 class="font-serif text-4xl font-bold text-[#f0c870]">Matches</h1>
    <p class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-semibold mt-2">
      <%= pluralize(@matches.size, "match") %> across <%= pluralize(@matches.map { |m| m.tournament_id }.uniq.size, "tournament") %>
    </p>
  </div>

  <% if @matches.any? %>
    <% match_years = @matches.map { |m| m.tournament.year }.uniq.sort.reverse %>

    <% if match_years.size > 1 %>
      <%= render "shared/year_filter", years: match_years %>
    <% end %>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <% @matches.each do |match| %>
        <div data-goal-filter-target="entry" data-year="<%= match.tournament.year %>">
          <%= render "matches/card", match: match %>
        </div>
      <% end %>
    </div>

    <p data-goal-filter-target="empty"
       class="hidden text-sm text-[#c89942] text-center mt-4 uppercase tracking-[0.25em] font-semibold">
      No matches in this tournament
    </p>
  <% else %>
    <p class="text-sm text-[#c89942] text-center uppercase tracking-[0.25em] font-semibold">
      No matches in our dataset yet
    </p>
  <% end %>
</div>
