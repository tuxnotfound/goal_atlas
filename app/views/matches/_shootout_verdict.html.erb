<%# GOAL (green) / MISS (red) outcome label for one penalty shootout kick.
    Sized + spaced for legibility — MISS especially needs to read clearly. %>
<span class="font-mono text-[11px] sm:text-xs uppercase font-bold tracking-wider shrink-0
             <%= kick.was_scored ? "text-[#1c5c3f]" : "text-[#b91c1c]" %>">
  <%= kick.was_scored ? "Goal" : "Miss" %>
</span>
