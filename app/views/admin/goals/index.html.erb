<% content_for :before_main do %>
  <%
    matches_scope = Match.kept.includes(:home_team, :away_team, :tournament).ordered_by_date
    matches_scope = matches_scope.where(tournament_id: params[:tournament_id]) if params[:tournament_id].present?
  %>
  <%= render "admin/shared/filter_form", filters: [
    { name: :tournament_id, label: "Tournament", options: Tournament.kept.ordered_by_year,
      label_for: ->(t) { "#{t.year} — #{t.host_countries.join(', ')}" },
      on_change_clear: [:match_id] },
    { name: :match_id,      label: "Match",      options: matches_scope,
      label_for: ->(m) { "#{m.tournament.year} ##{m.match_number}: #{m.home_team.fifa_code}-#{m.away_team.fifa_code}" } }
  ] %>
<% end %>

<%= render template: "administrate/application/index", locals: {
  page: page,
  resources: resources,
  search_term: search_term,
  show_search_bar: show_search_bar,
  filters: filters
} %>
