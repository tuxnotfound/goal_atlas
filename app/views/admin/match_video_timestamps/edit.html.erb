<% content_for(:title) { "Video timestamps — #{@match.home_team.fifa_code} v #{@match.away_team.fifa_code}" } %>

<header class="main-content__header">
  <h1 class="main-content__page-title">
    Video timestamps:
    <%= @match.home_team.name %> <%= @match.home_score %>–<%= @match.away_score %> <%= @match.away_team.name %>
  </h1>
  <div style="color: #666; font-size: 0.9rem;">
    <%= @match.date.to_fs(:long_ordinal) rescue @match.date %>
    · <%= @match.stage.to_s.humanize %>
    · <%= link_to "Back to match", admin_match_path(@match), style: "color: #1d4ed8;" %>
  </div>
</header>

<section class="main-content__body">
  <% if @match_video_links.any? %>
    <h2 style="margin-top: 0;">Match-level video (for reference)</h2>
    <ul style="list-style: none; padding-left: 0; margin: 0 0 1rem 0; display: flex; flex-direction: column; gap: 0.4rem;">
      <% @match_video_links.each do |link| %>
        <li>
          <%= link_to link.url, target: "_blank", rel: "noopener noreferrer", style: "color: #1d4ed8;" do %>
            <%= video_source_label(link) %> — <%= link.url %>
          <% end %>
          <%= link_to "edit", edit_admin_video_link_path(link), target: "_blank",
                      style: "color: #6b7280; font-size: 0.75rem; text-decoration: underline; margin-left: 0.4rem;" %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <%= form_with url: admin_match_video_timestamps_path(@match), method: :patch, local: true do |f| %>
    <h2>Goals</h2>

    <% if @goals.empty? %>
      <p style="color: #777;">This match has no goals.</p>
    <% end %>

    <% if @suggestions.any? %>
      <div style="margin-bottom: 0.75rem; padding: 0.5rem 0.75rem; background: #eff6ff; border-left: 3px solid #1d4ed8; font-size: 0.85rem; color: #1e3a8a;">
        <strong>Tip:</strong> <%= @suggestions.size %> goal link(s) have a heuristic timestamp suggestion (rough slot estimate from goal order ÷ video duration).
        Look for the dim "≈" placeholder; click <em>use</em> to accept, then scrub on YouTube to confirm.
      </div>
    <% end %>

    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <% @goals.each do |goal| %>
        <% goal_links = goal.video_links.kept.active.to_a %>
        <div style="border: 1px solid #e5e5e5; border-radius: 4px; padding: 0.75rem; background: #fafafa;">
          <div style="display: flex; gap: 0.5rem; align-items: baseline; flex-wrap: wrap;">
            <strong><%= goal.minute %>'<%= "+#{goal.stoppage_time}" if goal.stoppage_time.present? %></strong>
            <span><%= goal.player&.name %></span>
            <span style="color: #888; font-size: 0.85rem;">
              (<%= goal.scoring_team&.fifa_code %><% if goal.own_goal? %> — own goal<% end %>)
            </span>
            <span style="margin-left: auto; font-size: 0.8rem;">
              <%= link_to "View on site →", goal_path(goal.slug), target: "_blank", style: "color: #1d4ed8;" %>
            </span>
          </div>

          <% if goal_links.empty? %>
            <div style="color: #999; font-size: 0.85rem; margin-top: 0.4rem;">
              No video link yet. Run autofetch or
              <%= link_to "add one",
                          new_admin_video_link_path(linkable_type: "Goal", linkable_id: goal.id),
                          target: "_blank",
                          style: "color: #1d4ed8; text-decoration: underline;" %>.
            </div>
          <% else %>
            <div style="margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.4rem;">
              <% goal_links.each do |link| %>
                <% suggested = @suggestions[link.id] %>
                <% input_id = "vl_#{link.id}_starts" %>
                <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; font-size: 0.85rem;">
                  <span style="color: #555; min-width: 70px;"><%= video_source_label(link) %>:</span>
                  <%= link_to link.url, target: "_blank", rel: "noopener noreferrer",
                              style: "color: #1d4ed8; max-width: 50ch; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" do %>
                    <%= link.url.truncate(70) %>
                  <% end %>
                  <%= link_to "edit", edit_admin_video_link_path(link), target: "_blank",
                              style: "color: #6b7280; font-size: 0.75rem; text-decoration: underline;" %>
                  <label style="margin-left: auto; display: flex; gap: 0.4rem; align-items: center;">
                    Start at (m:ss):
                    <%= text_field_tag "video_links[#{link.id}][starts_at]",
                                       format_seconds_as_hms(link.starts_at_seconds),
                                       id: input_id,
                                       placeholder: suggested && link.starts_at_seconds.nil? ? "≈#{format_seconds_as_hms(suggested)}" : "m:ss",
                                       inputmode: "numeric",
                                       style: "width: 6rem; padding: 0.2rem 0.4rem;" %>
                  </label>
                  <button type="button"
                          class="js-open-video-at-timestamp"
                          data-video-url="<%= link.url %>"
                          data-video-source="<%= link.source %>"
                          data-input-id="<%= input_id %>"
                          style="padding: 0.2rem 0.5rem; font-size: 0.8rem; border: 1px solid #1d4ed8; color: #1d4ed8; background: white; border-radius: 3px; cursor: pointer;">
                    Open ↗
                  </button>
                  <%= hidden_field_tag "video_links[#{link.id}][timestamp_validated]", "0" %>
                  <label style="display: flex; gap: 0.3rem; align-items: center; color: <%= link.timestamp_validated_at? ? "#15803d" : "#666" %>;">
                    <%= check_box_tag "video_links[#{link.id}][timestamp_validated]", "1", link.timestamp_validated_at.present? %>
                    Validated<% if link.timestamp_validated_at.present? %>
                      <span style="color: #888; font-size: 0.75rem;">(<%= link.timestamp_validated_at.to_date.to_fs(:long) rescue link.timestamp_validated_at.to_date %>)</span>
                    <% end %>
                  </label>
                  <% if suggested && link.starts_at_seconds.nil? %>
                    <% suggested_hms = format_seconds_as_hms(suggested) %>
                    <a href="#" onclick="document.getElementById('<%= input_id %>').value='<%= suggested_hms %>';return false;"
                       style="color: #1d4ed8; font-size: 0.8rem;">use ≈<%= suggested_hms %></a>
                  <% end %>
                  <% if link.starts_at_seconds.present? %>
                    <span style="color: #888;">→ <%= format_seconds_as_hms(link.starts_at_seconds) %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div style="margin-top: 1rem;">
      <%= f.submit "Save all timestamps", class: "button button--success" %>
    </div>
  <% end %>
</section>

<script>
  (function() {
    // Accepts "443", "7:23", or "1:07:23" → total seconds. Returns null on invalid input.
    function parseHmsToSeconds(raw) {
      raw = (raw || "").trim();
      if (raw === "") return null;
      if (/^\d+$/.test(raw)) return parseInt(raw, 10);
      var parts = raw.split(":");
      if (parts.length < 2 || parts.length > 3) return null;
      var nums = parts.map(function(p) { return /^\d+$/.test(p) ? parseInt(p, 10) : NaN; });
      if (nums.some(function(n) { return isNaN(n); })) return null;
      if (parts.length === 2) return nums[0] * 60 + nums[1];
      return nums[0] * 3600 + nums[1] * 60 + nums[2];
    }

    function appendTimestamp(url, source, seconds) {
      var sep = url.indexOf("?") === -1 ? "?" : "&";
      // Detect by URL pattern, not source enum: many YouTube videos are
      // attached as source="other" (broadcaster / fan re-uploads) but still
      // need the &t=SECONDS suffix to seek.
      if (/(?:youtube\.com|youtu\.be)/i.test(url)) return url + sep + "t=" + seconds;
      if (source === "archive_org" || /archive\.org/i.test(url)) return url + sep + "start=" + seconds;
      return url;
    }

    document.querySelectorAll(".js-open-video-at-timestamp").forEach(function(btn) {
      btn.addEventListener("click", function(e) {
        e.preventDefault();
        var url = btn.getAttribute("data-video-url");
        var source = btn.getAttribute("data-video-source");
        var inputId = btn.getAttribute("data-input-id");
        var input = document.getElementById(inputId);
        var seconds = parseHmsToSeconds(input && input.value);
        if (seconds !== null) url = appendTimestamp(url, source, seconds);
        window.open(url, "_blank", "noopener,noreferrer");
      });
    });
  })();
</script>
