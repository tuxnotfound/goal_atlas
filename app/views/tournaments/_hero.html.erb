<%# Tournament hero — vintage football annual / Panini sticker spread feel.
    Parchment background, serif display year, forest-green ink with gold accents.
    Now centred on GOALS as the dominant stat and a real Olympic-style podium
    that emphasises the winner over the rest. %>
<section class="relative overflow-hidden rounded-lg mb-20 border-2 border-[#c89942]/70 shadow-xl shadow-black/30"
         style="background:#f5e7b8;">

  <%# World map watermark — prefers a painterly asset at public/hero_world_map.png
      if it exists, falls back to the inline Wikimedia SVG silhouette. %>
  <% map_asset = Rails.public_path.join("hero_world_map.png") %>
  <div class="absolute inset-0 pointer-events-none <%= File.exist?(map_asset) ? "opacity-25" : "text-[#1c5c3f] opacity-[0.12]" %>">
    <% if File.exist?(map_asset) %>
      <%= image_tag "/hero_world_map.png", alt: "", class: "w-full h-full object-cover" %>
    <% else %>
      <%= render "tournaments/world_map_svg" %>
    <% end %>
  </div>

  <%# Soft paper texture via layered radial gradients %>
  <div class="absolute inset-0 pointer-events-none opacity-70"
       style="background:
              radial-gradient(circle at 25% 15%, rgba(200,153,66,0.22), transparent 55%),
              radial-gradient(circle at 80% 80%, rgba(28,92,63,0.16), transparent 50%),
              radial-gradient(circle at 60% 40%, rgba(255,255,255,0.45), transparent 45%);"></div>

  <%# Decorative double-rule frame (like a magazine spread) %>
  <div class="absolute inset-3 border border-[#c89942]/40 rounded pointer-events-none"></div>

  <div class="relative grid grid-cols-1 md:grid-cols-12 gap-5 p-6 md:p-8">

    <%# === Left column: typographic hero === %>
    <div class="md:col-span-7 flex flex-col justify-between">
      <div>
        <div class="text-[11px] tracking-[0.4em] uppercase text-[#c89942] font-semibold">
          FIFA World Cup
        </div>

        <div class="font-serif font-bold leading-none text-[#0a3520] tabular-nums mt-1"
             style="font-size:clamp(3.5rem, 10vw, 6rem); letter-spacing:-0.02em;">
          <%= @tournament.year %>
        </div>

        <% if @tournament.host_countries.any? %>
          <div class="mt-2 flex items-center gap-3">
            <span class="font-serif italic text-xl md:text-2xl text-[#1c5c3f]">
              <%= @tournament.host_countries.join(" · ") %>
            </span>
          </div>
        <% end %>

        <% if @tournament.start_date && @tournament.end_date %>
          <div class="text-xs text-[#c89942] mt-1 tracking-[0.2em] uppercase font-semibold">
            <%= @tournament.start_date.strftime("%-d %b") %>
            &mdash;
            <%= @tournament.end_date.strftime("%-d %b %Y") %>
          </div>
        <% end %>
      </div>

      <%# Goals-first stat block: GOALS is the headline, matches + archive are secondary %>
      <% if @tournament.total_goals %>
        <div class="mt-5 flex items-end gap-5">
          <div>
            <div class="font-serif font-bold text-[#0a3520] tabular-nums leading-none"
                 style="font-size:clamp(2.5rem, 7vw, 4.5rem);">
              <%= @tournament.total_goals %>
            </div>
            <div class="text-[10px] uppercase tracking-[0.4em] text-[#c89942] mt-1 font-bold">
              Goals
            </div>
          </div>

          <div class="text-[11px] leading-relaxed text-[#1c5c3f] pb-1">
            <% if @tournament.total_matches %>
              across
              <span class="font-serif text-sm font-bold text-[#0a3520] tabular-nums"><%= @tournament.total_matches %></span>
              matches<br>
            <% end %>
            <span class="font-serif text-sm font-bold text-[#0a3520] tabular-nums"><%= @matches_by_stage.values.flatten.size %></span>
            in archive
          </div>
        </div>
      <% end %>
    </div>

    <%# === Right column: trophy — prefers a painterly asset at
         public/hero_trophy.png; falls back to the handwritten SVG. === %>
    <div class="md:col-span-5 flex items-center justify-center">
      <% trophy_asset = Rails.public_path.join("hero_trophy.png") %>
      <% if File.exist?(trophy_asset) %>
        <%= image_tag "/hero_trophy.png", alt: "FIFA World Cup trophy",
              class: "w-36 sm:w-40 md:w-44 lg:w-48 drop-shadow-xl" %>
      <% else %>
        <%= render "tournaments/trophy_svg" %>
      <% end %>
    </div>

    <%# ============================================================
         Final-standings podium — winner on the tallest gold block in
         the centre, runner-up on silver to the left, 3rd on bronze to
         the right. 4th gets a small chip below.
       ============================================================ %>
    <% w  = @tournament.winner_team %>
    <% ru = @tournament.runner_up_team %>
    <% th = @tournament.third_place_team %>
    <% fo = @tournament.fourth_place_team %>

    <% if w || ru || th %>
      <div class="md:col-span-12 mt-2 pt-6 border-t border-[#c89942]/40">
        <div class="text-[10px] uppercase tracking-[0.4em] text-[#c89942] font-semibold mb-6 text-center">
          Final Standings
        </div>

        <div class="flex items-end justify-center gap-3 sm:gap-5 max-w-2xl mx-auto">

          <%# 2nd — silver, left %>
          <% if ru %>
            <%= link_to team_path(ru), class: "flex flex-col items-center transition duration-200 ease-out hover:-translate-y-1" do %>
              <div class="text-3xl sm:text-4xl mb-1 leading-none"><%= ru.flag_emoji %></div>
              <div class="text-[11px] sm:text-xs font-bold tracking-wider text-[#1c5c3f] uppercase max-w-[110px] truncate">
                <%= ru.name %>
              </div>
              <div class="w-20 sm:w-24 h-20 sm:h-24 mt-2 rounded-t-md flex flex-col items-center justify-start pt-2 border-2 border-b-0 border-[#7a6438] shadow-md shadow-black/20"
                   style="background: linear-gradient(180deg, #e5d4a3, #b9a378);">
                <div class="font-serif text-3xl sm:text-4xl font-bold text-[#0a3520] leading-none">2</div>
                <div class="text-[8px] uppercase tracking-widest text-[#0a3520]/70 mt-1 font-semibold">Runner-up</div>
              </div>
            <% end %>
          <% end %>

          <%# 1st — gold, centre, tallest, with star %>
          <% if w %>
            <%= link_to team_path(w), class: "flex flex-col items-center transition duration-200 ease-out hover:-translate-y-1" do %>
              <div class="text-2xl mb-0.5 text-[#c89942] leading-none">★</div>
              <div class="text-4xl sm:text-5xl mb-1 leading-none"><%= w.flag_emoji %></div>
              <div class="text-xs sm:text-sm font-bold tracking-wider text-[#0a3520] uppercase max-w-[130px] truncate">
                <%= w.name %>
              </div>
              <div class="w-24 sm:w-28 h-28 sm:h-32 mt-2 rounded-t-md flex flex-col items-center justify-start pt-3 border-2 border-b-0 border-[#7a4b1a] shadow-lg shadow-black/30"
                   style="background: linear-gradient(180deg, #f0c870, #c89942);">
                <div class="font-serif text-4xl sm:text-5xl font-bold text-[#0a3520] leading-none">1</div>
                <div class="text-[9px] uppercase tracking-widest text-[#0a3520]/80 mt-1.5 font-bold">Champion</div>
              </div>
            <% end %>
          <% end %>

          <%# 3rd — bronze, right, shortest %>
          <% if th %>
            <%= link_to team_path(th), class: "flex flex-col items-center transition duration-200 ease-out hover:-translate-y-1" do %>
              <div class="text-3xl sm:text-4xl mb-1 leading-none"><%= th.flag_emoji %></div>
              <div class="text-[11px] sm:text-xs font-bold tracking-wider text-[#1c5c3f] uppercase max-w-[110px] truncate">
                <%= th.name %>
              </div>
              <div class="w-20 sm:w-24 h-16 sm:h-20 mt-2 rounded-t-md flex flex-col items-center justify-start pt-2 border-2 border-b-0 border-[#5a3614] shadow-md shadow-black/20"
                   style="background: linear-gradient(180deg, #cd8b4a, #8b4513);">
                <div class="font-serif text-3xl sm:text-4xl font-bold text-[#fef0c8] leading-none">3</div>
                <div class="text-[8px] uppercase tracking-widest text-[#fef0c8]/80 mt-1 font-semibold">Third</div>
              </div>
            <% end %>
          <% end %>
        </div>

        <%# 4th place — single line below the podium %>
        <% if fo %>
          <div class="text-center mt-5">
            <%= link_to team_path(fo), class: "inline-flex items-center gap-2 text-xs text-[#1c5c3f] hover:text-[#0a3520] transition" do %>
              <span class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-semibold">4th</span>
              <span class="text-lg leading-none"><%= fo.flag_emoji %></span>
              <span class="font-serif text-sm font-semibold"><%= fo.name %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
