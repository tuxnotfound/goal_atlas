<%# Tournament hero — V6: hero is full-width of its (constrained) parent so
    its left/right edges align with every section below. Nav arrows are
    absolute-positioned OUTSIDE those edges — the only elements that
    "break" the page border. %>
<div class="relative mb-20">

  <%# === Hero === %>
  <section class="relative overflow-hidden rounded-lg border-2 border-[#c89942]/70 shadow-xl shadow-black/30"
           style="background:#f5e7b8;">

    <%# World map watermark %>
    <% map_asset = Rails.public_path.join("hero_world_map.png") %>
    <div class="absolute inset-0 pointer-events-none <%= File.exist?(map_asset) ? "opacity-25" : "text-[#1c5c3f] opacity-[0.12]" %>">
      <% if File.exist?(map_asset) %>
        <%= image_tag "/hero_world_map.png", alt: "", class: "w-full h-full object-cover" %>
      <% else %>
        <%= render "tournaments/world_map_svg" %>
      <% end %>
    </div>

    <%# Soft paper texture %>
    <div class="absolute inset-0 pointer-events-none opacity-60"
         style="background:
                radial-gradient(circle at 25% 15%, rgba(200,153,66,0.22), transparent 55%),
                radial-gradient(circle at 80% 80%, rgba(28,92,63,0.16), transparent 50%),
                radial-gradient(circle at 60% 40%, rgba(255,255,255,0.45), transparent 45%);"></div>

    <%# Decorative double-rule frame %>
    <div class="absolute inset-3 border border-[#c89942]/40 rounded pointer-events-none"></div>

    <%# Trophy %>
    <% trophy_asset = Rails.public_path.join("hero_trophy.png") %>
    <% if File.exist?(trophy_asset) %>
      <%= image_tag "/hero_trophy.png", alt: "FIFA World Cup trophy",
            class: "absolute -top-3 sm:-top-6 right-0 sm:right-4 h-[240px] sm:h-[460px] md:h-[750px] w-auto pointer-events-none drop-shadow-2xl select-none" %>
    <% else %>
      <div class="absolute top-4 right-4 pointer-events-none">
        <%= render "tournaments/trophy_svg" %>
      </div>
    <% end %>

    <%# === Content: 3-column grid. min-h matches the natural height of a
         finished tournament's hero (year + host + dates + goals stats on the
         left, podium + 4th line on the right), so upcoming tournaments
         without those data points still hold the same card shape and the
         navigation between editions doesn't visibly jump. === %>
    <div class="relative p-6 md:p-8 md:min-h-[440px] grid grid-cols-12 gap-6 items-stretch">

      <%# Column 1 — eyebrow + year + host + dates + goals.
          Trimmed from col-span-4 to col-span-3 so the podium beside it shifts
          left and clears the trophy. %>
      <div class="col-span-12 sm:col-span-5 md:col-span-3 flex flex-col gap-4">

        <div>
          <div class="text-[11px] tracking-[0.4em] uppercase text-[#c89942] font-semibold">
            FIFA World Cup
          </div>
          <div class="font-serif font-bold leading-none text-[#0a3520] tabular-nums mt-1"
               style="font-size:clamp(3.5rem, 9vw, 5.5rem); letter-spacing:-0.02em;">
            <%= @tournament.year %>
          </div>
        </div>

        <% if @tournament.host_countries.any? %>
          <div>
            <span class="font-serif italic text-xl md:text-2xl text-[#1c5c3f]">
              <%= @tournament.host_countries.join(" · ") %>
            </span>
          </div>
        <% end %>

        <% if @tournament.start_date && @tournament.end_date %>
          <div class="text-xs text-[#c89942] tracking-[0.2em] uppercase font-semibold -mt-2">
            <%= @tournament.start_date.strftime("%-d %b") %>
            &mdash;
            <%= @tournament.end_date.strftime("%-d %b %Y") %>
          </div>
        <% end %>

        <% if @tournament.total_goals %>
          <div class="mt-1">
            <div class="font-serif font-bold text-[#0a3520] tabular-nums leading-none"
                 style="font-size:clamp(2.25rem, 6.5vw, 4rem);">
              <%= @tournament.total_goals %>
            </div>
            <div class="text-[10px] uppercase tracking-[0.4em] text-[#c89942] mt-1 font-bold">
              Goals
            </div>
            <% if @tournament.total_matches %>
              <div class="text-[11px] text-[#1c5c3f] mt-1">
                across
                <span class="font-serif text-sm font-bold text-[#0a3520] tabular-nums"><%= @tournament.total_matches %></span>
                matches
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Column 2 — Final Standings podium, anchored to the bottom of the
          column, with each team name sitting directly under its block. %>
      <% w  = @tournament.winner_team %>
      <% ru = @tournament.runner_up_team %>
      <% th = @tournament.third_place_team %>
      <% fo = @tournament.fourth_place_team %>

      <% if w || ru || th %>
        <%# Fixed-width podium columns. Team names use full text — long names
            wrap to two lines within the column rather than truncating with
            ellipsis. Sizes bumped one notch from v7 across the board. %>
        <div class="col-span-12 sm:col-span-7 md:col-span-5 flex flex-col justify-end">
          <div class="overflow-x-clip">
          <div class="hero-podium-fit flex items-end justify-center gap-3">

            <%# 2nd — silver %>
            <% if ru %>
              <%= link_to team_path(ru), class: "flex flex-col items-center w-28 transition duration-200 ease-out hover:-translate-y-0.5", title: "Runner-up: #{ru.name}" do %>
                <div class="text-3xl leading-none mb-1"><%= ru.flag_emoji %></div>
                <div class="w-28 h-28 rounded-t-md flex items-center justify-center border-2 border-b-0 border-[#7a6438] shadow-md shadow-black/20"
                     style="background: linear-gradient(180deg, #e5d4a3, #b9a378);">
                  <div class="font-serif text-5xl font-bold text-[#0a3520] leading-none">2</div>
                </div>
                <div class="text-[10px] font-bold tracking-wider text-[#1c5c3f] uppercase mt-2 w-full text-center leading-tight wrap-break-word h-7">
                  <%= ru.name %>
                </div>
              <% end %>
            <% else %>
              <div class="w-28"></div>
            <% end %>

            <%# 1st — gold, tallest %>
            <% if w %>
              <%= link_to team_path(w), class: "flex flex-col items-center w-32 transition duration-200 ease-out hover:-translate-y-0.5", title: "Champion: #{w.name}" do %>
                <div class="text-lg leading-none text-[#c89942]">★</div>
                <div class="text-4xl leading-none my-0.5"><%= w.flag_emoji %></div>
                <div class="w-32 h-36 rounded-t-md flex items-center justify-center border-2 border-b-0 border-[#7a4b1a] shadow-lg shadow-black/30"
                     style="background: linear-gradient(180deg, #f0c870, #c89942);">
                  <div class="font-serif text-6xl font-bold text-[#0a3520] leading-none">1</div>
                </div>
                <div class="text-[10px] font-bold tracking-wider text-[#0a3520] uppercase mt-2 w-full text-center leading-tight wrap-break-word h-7">
                  <%= w.name %>
                </div>
              <% end %>
            <% else %>
              <div class="w-32"></div>
            <% end %>

            <%# 3rd — bronze %>
            <% if th %>
              <%= link_to team_path(th), class: "flex flex-col items-center w-28 transition duration-200 ease-out hover:-translate-y-0.5", title: "Third: #{th.name}" do %>
                <div class="text-3xl leading-none mb-1"><%= th.flag_emoji %></div>
                <div class="w-28 h-24 rounded-t-md flex items-center justify-center border-2 border-b-0 border-[#5a3614] shadow-md shadow-black/20"
                     style="background: linear-gradient(180deg, #cd8b4a, #8b4513);">
                  <div class="font-serif text-5xl font-bold text-[#0a3520] leading-none">3</div>
                </div>
                <div class="text-[10px] font-bold tracking-wider text-[#1c5c3f] uppercase mt-2 w-full text-center leading-tight wrap-break-word h-7">
                  <%= th.name %>
                </div>
              <% end %>
            <% else %>
              <div class="w-28"></div>
            <% end %>

          </div>
          </div>

          <%# 4th place — small single line beneath the podium, centred. %>
          <% if fo %>
            <div class="flex justify-center mt-3">
              <%= link_to team_path(fo), class: "inline-flex items-center gap-1 transition hover:-translate-y-0.5", title: "4th: #{fo.name}" do %>
                <span class="text-[8px] uppercase tracking-[0.3em] text-[#c89942] font-semibold">4th</span>
                <span class="text-xs leading-none"><%= fo.flag_emoji %></span>
                <span class="text-[9px] font-bold tracking-wider text-[#1c5c3f] uppercase">
                  <%= fo.name %>
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <% tournament_lead_text = tournament_lead(@tournament) %>
    <% if tournament_lead_text.present? %>
      <div class="relative border-t border-[#c89942]/40" style="background:#f5e7b8;">
        <div class="relative px-6 md:px-10 py-4">
          <p class="font-serif text-sm md:text-base leading-relaxed text-[#0a3520] max-w-3xl mx-auto">
            <%= tournament_lead_text %>
          </p>
        </div>
      </div>
    <% end %>
  </section>

  <%# === Nav arrows — absolute-positioned outside the hero's left/right
       edges. Discrete by default (low opacity, soft fill); pop on hover. === %>
  <% if @next_tournament %>
    <%= link_to tournament_path(year: @next_tournament.year),
                title: "#{@next_tournament.year} World Cup",
                class: "absolute left-1 md:-left-12 top-1/2 -translate-y-1/2 w-10 h-10 md:w-9 md:h-9 rounded-full border border-[#c89942]/50 bg-[#fdf6dc] text-[#0a3520] flex items-center justify-center transition shadow-md shadow-black/20 opacity-80 md:opacity-55 hover:opacity-100 hover:bg-[#fef0c8] hover:border-[#f0c870] hover:shadow-lg" do %>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
      </svg>
    <% end %>
  <% end %>

  <% if @prev_tournament %>
    <%= link_to tournament_path(year: @prev_tournament.year),
                title: "#{@prev_tournament.year} World Cup",
                class: "absolute right-1 md:-right-12 top-1/2 -translate-y-1/2 w-10 h-10 md:w-9 md:h-9 rounded-full border border-[#c89942]/50 bg-[#fdf6dc] text-[#0a3520] flex items-center justify-center transition shadow-md shadow-black/20 opacity-80 md:opacity-55 hover:opacity-100 hover:bg-[#fef0c8] hover:border-[#f0c870] hover:shadow-lg" do %>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M10 6 8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
      </svg>
    <% end %>
  <% end %>
</div>
