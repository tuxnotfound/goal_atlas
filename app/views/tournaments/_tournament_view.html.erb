<%# Tournament view — pill row + horizontally-sliding stages.
    Each pill switches both:
      * The outer stages wrapper (slides between GS / knockout panels)
      * The inner bracket track (pans between R16 / QF / SF / F columns) %>
<%
  stage_meta = {
    "group_stage"          => { abbr: "GS",  label: "Group stage" },
    "second_group_stage"   => { abbr: "GS2", label: "Second group stage" },
    "round_of_32"          => { abbr: "R32", label: "Round of 32" },
    "round_of_16"          => { abbr: "R16", label: "Round of 16" },
    "quarter_final"        => { abbr: "QF",  label: "Quarter-finals" },
    "semi_final"           => { abbr: "SF",  label: "Semi-finals" },
    "final"                => { abbr: "F",   label: "Final" }
  }

  available_stages = stage_meta.keys.select do |s|
    case s
    when "group_stage"        then @group_standings.present?
    when "second_group_stage" then @matches_by_stage["second_group_stage"]&.any?
    else                           @matches_by_stage[s]&.any?
    end
  end

  # ===== Bracket geometry =====
  # The bracket adapts to whichever rounds the tournament actually has: 1986+
  # get the full R16+QF+SF+F layout, 1954–1970 get QF+SF+F, 1930/1982 get
  # SF+F, 1974/1978 get a synthetic group_outcome+F layout, and tournaments
  # without even a Final fall through to standalone panels.
  card_w        = 240
  card_h        = 64
  final_w       = 280
  final_h       = 150
  third_w       = 220
  inter_col_gap = 80
  slot_h        = 84
  left_pad      = 24

  round_match_count = { round_of_16: 8, quarter_final: 4, semi_final: 2, final: 1, group_outcome: 2 }
  pillable_rounds   = [:round_of_16, :quarter_final, :semi_final, :final]

  if @bracket
    rounds_in_bracket = @bracket[:rounds]

    total_slots = round_match_count[rounds_in_bracket.first]
    total_h     = slot_h * total_slots

    round_x = {}
    cur_x   = 0
    rounds_in_bracket.each do |r|
      round_x[r] = cur_x
      cur_x += (r == :final ? final_w : card_w) + inter_col_gap
    end

    round_ys = rounds_in_bracket.each_with_object({}) do |r, h|
      count = round_match_count[r]
      h[r]  = (0...count).map { |i| (i + 0.5) * (total_h.to_f / count) }
    end

    final_y = round_ys[:final].first
    track_w = round_x[:final] + final_w + 32
    x_third = round_x[:final] + (final_w - third_w) / 2.0

    third_label_y = final_y + final_h / 2.0 + 22
    third_card_y  = third_label_y + 14 + 10 + card_h / 2.0

    panel_h = @bracket[:third_place] ? [total_h, third_card_y + card_h / 2.0 + 16].max : total_h

    cells_by_round = {
      round_of_16:    @bracket[:round_of_16],
      quarter_final:  @bracket[:quarters],
      semi_final:     @bracket[:semis],
      final:          [@bracket[:final]],
      group_outcome:  @bracket[:group_outcomes]
    }

    # When the bracket has only one stage that owns a pill (1974/1978: only F),
    # panning would push the only other column off-screen on click. Anchor
    # every pill to the leftmost column so the whole bracket stays visible.
    bracket_pill_rounds = rounds_in_bracket & pillable_rounds
    if bracket_pill_rounds.size <= 1
      fixed_offset = left_pad - round_x[rounds_in_bracket.first]
      offsets = rounds_in_bracket.each_with_object({}) { |r, h| h[r.to_s] = fixed_offset }
    else
      offsets = rounds_in_bracket.each_with_object({}) do |r, h|
        h[r.to_s] = left_pad - round_x[r]
      end
    end
  else
    rounds_in_bracket = []
    offsets           = {}
  end

  connector = ->(from_x, from_y, to_x, to_y) {
    mid_x = (from_x + to_x) / 2.0
    "M #{from_x} #{from_y} H #{mid_x} V #{to_y} H #{to_x}"
  }

  # ===== Panel ordering for the outer slide =====
  # Each panel occupies one slot in the stagesWrapper. Bracket rounds share
  # the bracket panel's slot (inner pan handles which column is visible);
  # any knockout rounds that exist but aren't in the bracket (e.g. 1934 QF
  # replays) get their own standalone panel afterwards.
  stage_indices = {}
  panel_count   = 0

  if @group_standings.present?
    stage_indices["group_stage"] = panel_count
    panel_count += 1
  end

  if @matches_by_stage["second_group_stage"]&.any?
    stage_indices["second_group_stage"] = panel_count
    panel_count += 1
  end

  if @matches_by_stage["round_of_32"]&.any? && !@bracket
    stage_indices["round_of_32"] = panel_count
    panel_count += 1
  end

  if @bracket
    bracket_idx = panel_count
    rounds_in_bracket.each { |s| stage_indices[s.to_s] = bracket_idx }
    panel_count += 1
  end

  %w[round_of_16 quarter_final semi_final final].each do |s|
    next if stage_indices.key?(s)
    next unless @matches_by_stage[s]&.any?
    stage_indices[s] = panel_count
    panel_count += 1
  end
%>

<% if available_stages.any? %>
  <section class="mb-24" data-controller="stage-selector"
           data-stage-selector-offsets-value="<%= offsets.to_json %>"
           data-stage-selector-stage-indices-value="<%= stage_indices.to_json %>">

    <%# === Stage pill row + progress indicator (grouped so the indicator
         track only spans as wide as the actual pills, not the section). === %>
    <div class="w-fit max-w-full mb-6">
    <div class="flex gap-2 mb-2 overflow-x-auto pb-2 -mx-1 px-1">
      <% available_stages.each_with_index do |stage, idx| %>
        <% meta = stage_meta[stage] %>
        <% is_final = stage == "final" %>
        <button type="button"
                data-stage-selector-target="pill"
                data-stage="<%= stage %>"
                data-active="<%= idx == 0 ? "true" : "false" %>"
                data-action="click->stage-selector#select focus->stage-selector#select"
                class="group shrink-0 flex items-center gap-1.5 px-4 py-2 rounded-full border font-mono text-xs tracking-[0.2em] uppercase font-semibold transition
                       border-[#c89942]/45 text-[#c89942] hover:border-[#f0c870]
                       data-[active=true]:bg-[#f0c870] data-[active=true]:text-[#fef0c8]! data-[active=true]:border-[#f0c870] data-[active=true]:shadow-md data-[active=true]:shadow-black/30 data-[active=true]:font-bold"
                style="background:rgba(253,246,220,0.06);">
          <span><%= meta[:abbr] %></span>
          <% if is_final %>
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M7 4h10v2h3v3a4 4 0 0 1-4 4h-.18A5 5 0 0 1 13 16.9V19h3v2H8v-2h3v-2.1A5 5 0 0 1 7.18 13H7a4 4 0 0 1-4-4V6h3V4h1zm0 4H5v1a2 2 0 0 0 2 2V8zm10 0v3a2 2 0 0 0 2-2V8h-2z"/>
            </svg>
          <% end %>
        </button>
      <% end %>
    </div>

    <%# Progress indicator track + dot, sized to the wrapper above. %>
    <div class="relative h-px bg-[#c89942]/25 mx-1"
         data-stage-selector-target="indicatorTrack">
      <div class="absolute -top-1 w-2 h-2 -translate-x-1/2 rounded-full bg-[#f0c870] shadow shadow-black/40"
           data-stage-selector-target="indicator"
           style="left: 0; transition: left 500ms cubic-bezier(0.4, 0, 0.2, 1);"></div>
    </div>
    </div>

    <%# === Horizontally-sliding stages === %>
    <div class="overflow-x-hidden">
      <div data-stage-selector-target="stagesWrapper"
           class="flex transition-transform duration-500 ease-out"
           style="transform: translateX(0%);">

        <%# --- Group stage panel: CSS multi-column so cards in column 2 don't get
             stranded under a tall expanded card in column 1. --- %>
        <% if @group_standings.present? %>
          <div class="shrink-0 w-full">
            <div class="columns-1 sm:columns-2 gap-4 [column-fill:balance]">
              <%= render "tournaments/group_cards", standings: @group_standings, matches: @group_matches %>
            </div>
          </div>
        <% end %>

        <%# --- Second group stage — same standings-table treatment as the
             regular group stage. Single-group years (1950) show as one
             untitled "Final round" table. --- %>
        <% if @second_group_standings.present? %>
          <div class="shrink-0 w-full">
            <div class="columns-1 sm:columns-2 gap-4 [column-fill:balance]">
              <%= render "tournaments/group_cards", standings: @second_group_standings, matches: @second_group_matches %>
            </div>
          </div>
        <% end %>

        <%# --- R32 fallback (rare; only when no full bracket) --- %>
        <% if @matches_by_stage["round_of_32"]&.any? && !@bracket %>
          <div class="shrink-0 w-full">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              <% @matches_by_stage["round_of_32"].each do |m| %>
                <%= render "tournaments/match_card_compact", match: m %>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# --- Bracket panel (any prefix of R16 / QF / SF / F, with internal pan) --- %>
        <% if @bracket %>
          <% initial_offset = offsets[rounds_in_bracket.first.to_s] %>
          <div class="shrink-0 w-full">
            <div class="overflow-x-hidden rounded-md">
              <div data-stage-selector-target="bracketTrack"
                   class="relative transition-transform duration-500 ease-out"
                   style="width:<%= track_w %>px; height:<%= panel_h %>px; transform: translateX(<%= initial_offset %>px);">

                <%# Connectors — one pass per adjacent pair of bracket rounds,
                    plus a dashed pair from the SFs down to the third-place card. %>
                <svg class="absolute inset-0 pointer-events-none"
                     viewBox="0 0 <%= track_w %> <%= panel_h %>"
                     style="overflow:visible;">
                  <% rounds_in_bracket.each_cons(2) do |left, right| %>
                    <% left_cells  = cells_by_round[left] %>
                    <% right_cells = cells_by_round[right] %>
                    <% is_to_final = right == :final %>
                    <% right_cells.each_with_index do |right_cell, r_idx| %>
                      <% next unless right_cell %>
                      <% [2 * r_idx, 2 * r_idx + 1].each do |l_idx| %>
                        <% next unless left_cells[l_idx] %>
                        <path d="<%= connector.call(round_x[left] + card_w, round_ys[left][l_idx], round_x[right], round_ys[right][r_idx]) %>"
                              stroke="<%= is_to_final ? "#f0c870" : "#c89942" %>"
                              stroke-width="<%= is_to_final ? "1.6" : "1.2" %>"
                              fill="none"
                              opacity="<%= is_to_final ? "0.95" : "0.7" %>"/>
                      <% end %>
                    <% end %>
                  <% end %>
                  <% if @bracket[:third_place] && rounds_in_bracket.include?(:semi_final) %>
                    <% sf_right = round_x[:semi_final] + card_w %>
                    <% conv_y   = third_label_y - 10 %>
                    <% center_x = x_third + third_w / 2.0 %>
                    <path d="M <%= sf_right %> <%= round_ys[:semi_final][0] + card_h / 2.0 %>
                             V <%= conv_y %>
                             H <%= center_x %>"
                          stroke="#c89942" stroke-width="0.9" stroke-dasharray="3 3" fill="none" opacity="0.45"/>
                    <path d="M <%= sf_right %> <%= round_ys[:semi_final][1] + card_h / 2.0 %>
                             V <%= conv_y %>"
                          stroke="#c89942" stroke-width="0.9" stroke-dasharray="3 3" fill="none" opacity="0.45"/>
                  <% end %>
                </svg>

                <%# Non-final round cards — render a bracket_card, bye_card, or
                    group_outcome_card depending on what's in the slot. %>
                <% rounds_in_bracket.each do |round_name| %>
                  <% next if round_name == :final %>
                  <% cells_by_round[round_name].each_with_index do |cell, i| %>
                    <% next unless cell %>
                    <div class="absolute transition-all duration-300 ease-out origin-center"
                         data-stage="<%= round_name %>"
                         style="left:<%= round_x[round_name] %>px; top:<%= round_ys[round_name][i] - card_h / 2.0 %>px; width:<%= card_w %>px;">
                      <% if round_name == :group_outcome %>
                        <%= render "tournaments/group_outcome_card", node: cell %>
                      <% elsif cell.is_a?(Hash) && cell[:bye] %>
                        <%= render "tournaments/bye_card", team: cell[:team] %>
                      <% else %>
                        <%= render "tournaments/bracket_card", match: cell %>
                      <% end %>
                    </div>
                  <% end %>
                <% end %>

                <%# Final card %>
                <div class="absolute transition-all duration-300 ease-out origin-center"
                     data-stage="final"
                     style="left:<%= round_x[:final] %>px; top:<%= final_y - final_h / 2.0 %>px; width:<%= final_w %>px;">
                  <%= render "tournaments/final_card", match: @bracket[:final] %>
                </div>

                <%# Third place beneath the Final %>
                <% if @bracket[:third_place] %>
                  <div class="absolute transition-all duration-300 ease-out origin-center text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-semibold text-center"
                       data-stage="final"
                       style="left:<%= x_third %>px; top:<%= third_label_y %>px; width:<%= third_w %>px;">
                    Third place
                  </div>
                  <div class="absolute transition-all duration-300 ease-out origin-center"
                       data-stage="final"
                       style="left:<%= x_third %>px; top:<%= third_card_y - card_h / 2.0 %>px; width:<%= third_w %>px;">
                    <%= render "tournaments/bracket_card", match: @bracket[:third_place] %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <%# --- Standalone knockout panels: any rounds that exist but aren't in
             the bracket (e.g. 1934/1938 QFs with replays, or 1974/1978 finals
             reached straight from a second group stage). --- %>
        <% %w[round_of_16 quarter_final semi_final final].each do |stage| %>
          <% next if @bracket && @bracket[:rounds].include?(stage.to_sym) %>
          <% next unless @matches_by_stage[stage]&.any? %>
          <div class="shrink-0 w-full">
            <% if stage == "final" %>
              <% final_match = @matches_by_stage["final"].first %>
              <% third_match = @matches_by_stage["third_place_playoff"]&.first %>
              <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class="md:w-1/2 max-w-md mx-auto md:mx-0 w-full">
                  <%= render "tournaments/final_card", match: final_match %>
                </div>
                <% if third_match %>
                  <div class="md:w-1/2 max-w-md w-full">
                    <div class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-semibold mb-2">
                      Third place
                    </div>
                    <%= render "tournaments/match_card_compact", match: third_match %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <% @matches_by_stage[stage].each do |m| %>
                  <%= render "tournaments/match_card_compact", match: m %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
