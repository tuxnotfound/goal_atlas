<% seo_for title: @tournament.name,
           description: "#{@tournament.name}: group stage, knockout bracket, results, goal highlights, awards, and the golden boot race." %>

<%# Page width container — every tournament-page section aligns to these
    horizontal edges. The hero's left/right edges define the "page border",
    and only the hero's nav arrows are allowed to sit outside it. %>
<div class="max-w-6xl mx-auto">

<%= render "shared/breadcrumbs", crumbs: [
  ["World Cups", tournaments_path],
  [@tournament.name, nil]
] %>
<%= render "shared/structured_data/tournament", tournament: @tournament %>

<%= render "tournaments/hero" %>

<%= render "shared/structured_data/tournament_faq", tournament: @tournament %>

<%# === Tournament view (stage-by-stage) === %>
<%= render "tournaments/tournament_view" %>

<%# === Awards & Golden boot — two side-by-side columns. Left column holds the
       ball podium (Golden/Silver/Bronze) plus any other awards (Glove, Young
       Player, Fair Play, etc.); right column holds the Golden boot podium.
       When only one side has data the grid collapses to a single column. === %>
<% non_boot_awards = @awards.reject { |a| a.display_name.to_s.downcase.include?("boot") } %>
<% golden_ball  = non_boot_awards.find { |a| a.display_name.to_s.downcase.include?("golden ball") } %>
<% silver_ball  = non_boot_awards.find { |a| a.display_name.to_s.downcase.include?("silver ball") } %>
<% bronze_ball  = non_boot_awards.find { |a| a.display_name.to_s.downcase.include?("bronze ball") } %>
<% other_awards = non_boot_awards - [golden_ball, silver_ball, bronze_ball].compact %>

<% has_awards = non_boot_awards.any? %>
<% has_boot   = @top_scorers.any? %>

<% if has_awards || has_boot %>
  <% two_col = has_awards && has_boot %>
  <section class="mb-10">
    <h2 class="font-serif text-2xl text-[#f0c870] mb-1 text-center">Awards</h2>
    <p class="text-[10px] uppercase tracking-[0.3em] text-[#c89942] font-semibold text-center mb-10">
      The tournament's standout performers
    </p>

    <div class="grid grid-cols-1 <%= "lg:grid-cols-2" if two_col %> gap-y-16 gap-x-16 lg:gap-x-28 items-start">

      <%# --- Left column: ball podium + other awards --- %>
      <% if has_awards %>
        <div>
          <%# Ball podium row — Silver | Golden (featured) | Bronze. Sizes tightened
              so the three feel like a single trio rather than a giant + two minis. %>
          <% if golden_ball || silver_ball || bronze_ball %>
            <div class="overflow-x-clip mb-10">
            <div class="podium-fit flex items-end justify-center gap-6 sm:gap-10">

              <%# Silver Ball %>
              <% if silver_ball %>
                <div class="flex flex-col items-center">
                  <div class="text-[10px] uppercase tracking-[0.35em] text-[#c89942] font-bold text-center mb-3">
                    <%= silver_ball.display_name %>
                  </div>
                  <%= render "players/card", player: silver_ball.player, tournament: @tournament, size: 130 %>
                </div>
              <% end %>

              <%# Golden Ball — featured %>
              <% if golden_ball %>
                <div class="flex flex-col items-center">
                  <div class="flex items-center justify-center text-center gap-3 text-[12px] uppercase tracking-[0.45em] text-[#f0c870] font-bold mb-1">
                    <span class="text-base">★</span>
                    <span><%= golden_ball.display_name %></span>
                    <span class="text-base">★</span>
                  </div>
                  <p class="text-[9px] uppercase tracking-[0.3em] text-[#c89942] font-semibold text-center mb-3">
                    Player of the tournament
                  </p>
                  <%= render "players/card", player: golden_ball.player, tournament: @tournament, size: 170 %>
                </div>
              <% end %>

              <%# Bronze Ball %>
              <% if bronze_ball %>
                <div class="flex flex-col items-center">
                  <div class="text-[10px] uppercase tracking-[0.35em] text-[#c89942] font-bold text-center mb-3">
                    <%= bronze_ball.display_name %>
                  </div>
                  <%= render "players/card", player: bronze_ball.player, tournament: @tournament, size: 130 %>
                </div>
              <% end %>
            </div>
            </div>
          <% end %>

          <%# Other awards — flex-wrap with justify-center so the row stays centred
              even when there are only 1 or 2 awards. %>
          <% if other_awards.any? %>
            <div class="flex flex-wrap justify-center gap-x-10 gap-y-6">
              <% other_awards.each do |award| %>
                <div class="flex flex-col items-center">
                  <div class="text-[10px] uppercase tracking-[0.35em] text-[#c89942] font-bold text-center leading-tight min-h-[2.4em] flex items-center px-1">
                    <%= award.display_name %>
                  </div>
                  <svg class="w-5 h-5 text-[#c89942] mt-1 mb-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M7 4h10v2h3v3a4 4 0 0 1-4 4h-.18A5 5 0 0 1 13 16.9V19h3v2H8v-2h3v-2.1A5 5 0 0 1 7.18 13H7a4 4 0 0 1-4-4V6h3V4h1zm0 4H5v1a2 2 0 0 0 2 2V8zm10 0v3a2 2 0 0 0 2-2V8h-2z"/>
                  </svg>
                  <%= render "players/card", player: award.player, tournament: @tournament, size: 130 %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# --- Right column: Golden boot podium (top 3 emphasised) --- %>
      <% if has_boot %>
        <div>
          <%# Podium: top 3 — silver | gold | bronze. Card sizes match the ball
              trio: 170 for the winner, 130 for runner-ups. Step widths pixel-match
              the cards so each player stands flush on their step. %>
          <% podium_scorers = [
               { rank: 2, scorer: @top_scorers[1], award: "Silver Boot", subtitle: "2nd top scorer",
                 card_size: 130, step_w: "w-[130px]",
                 step_h: "h-32 sm:h-40", grad: "linear-gradient(180deg, #e5d4a3, #b9a378)",
                 border: "border-[#7a6438]", num_color: "text-[#0a3520]", label_color: "text-[#0a3520]/70",
                 num_size: "text-4xl sm:text-5xl" },
               { rank: 1, scorer: @top_scorers[0], award: "Golden Boot", subtitle: "Top scorer",
                 card_size: 170, step_w: "w-[170px]",
                 step_h: "h-44 sm:h-56", grad: "linear-gradient(180deg, #f0c870, #c89942)",
                 border: "border-[#7a4b1a]", num_color: "text-[#0a3520]", label_color: "text-[#0a3520]/80",
                 num_size: "text-5xl sm:text-6xl" },
               { rank: 3, scorer: @top_scorers[2], award: "Bronze Boot", subtitle: "3rd top scorer",
                 card_size: 130, step_w: "w-[130px]",
                 step_h: "h-28 sm:h-32", grad: "linear-gradient(180deg, #cd8b4a, #8b4513)",
                 border: "border-[#5a3614]", num_color: "text-[#fef0c8]", label_color: "text-[#fef0c8]/80",
                 num_size: "text-4xl sm:text-5xl" }
             ] %>

          <div class="overflow-x-clip">
          <div class="podium-fit flex items-end justify-center gap-4 sm:gap-8 max-w-4xl mx-auto">
            <% podium_scorers.each do |slot| %>
              <% scorer = slot[:scorer] %>
              <% next unless scorer %>
              <% is_winner = slot[:rank] == 1 %>

              <div class="flex flex-col items-center">
                <% if is_winner %>
                  <div class="flex items-center justify-center text-center gap-3 text-[12px] uppercase tracking-[0.45em] text-[#f0c870] font-bold mb-1">
                    <span class="text-base">★</span>
                    <span><%= slot[:award] %></span>
                    <span class="text-base">★</span>
                  </div>
                  <p class="text-[9px] uppercase tracking-[0.3em] text-[#c89942] font-semibold text-center mb-3">
                    <%= slot[:subtitle] %>
                  </p>
                <% else %>
                  <div class="text-[10px] uppercase tracking-[0.35em] text-[#c89942] font-bold text-center mb-3">
                    <%= slot[:award] %>
                  </div>
                <% end %>

                <%= render "players/card", player: scorer, tournament: @tournament, size: slot[:card_size] %>

                <div class="<%= slot[:step_w] %> <%= slot[:step_h] %> mt-2 rounded-t-md flex flex-col items-center justify-center border-2 border-b-0 <%= slot[:border] %> shadow-md shadow-black/25"
                     style="background: <%= slot[:grad] %>;">
                  <div class="font-serif <%= slot[:num_size] %> font-bold leading-none <%= slot[:num_color] %>">
                    <%= scorer.goals_count %>
                  </div>
                  <div class="text-[10px] uppercase tracking-widest mt-2 font-semibold <%= slot[:label_color] %>">
                    <%= scorer.goals_count == 1 ? "Goal" : "Goals" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          </div>
        </div>
      <% end %>

    </div>
  </section>
<% end %>

</div>


