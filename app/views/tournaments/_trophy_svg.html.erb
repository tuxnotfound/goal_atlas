<%# Stylized FIFA World Cup trophy — flame-shaped body with the characteristic
    figure-waist + lower-hip flare, two malachite-banded base tiers, small globe on top. %>
<svg viewBox="0 0 100 220" class="w-36 sm:w-40 md:w-44 lg:w-48 drop-shadow-xl"
     xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="trophyGold" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"  stop-color="#fef0c8"/>
      <stop offset="22%" stop-color="#f0c870"/>
      <stop offset="55%" stop-color="#c98c3a"/>
      <stop offset="100%" stop-color="#6a3f12"/>
    </linearGradient>
    <linearGradient id="trophyGoldBase" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"  stop-color="#f5d68e"/>
      <stop offset="50%" stop-color="#d29a48"/>
      <stop offset="100%" stop-color="#7a4b1a"/>
    </linearGradient>
    <radialGradient id="trophyGlobe" cx="0.32" cy="0.28">
      <stop offset="0%"  stop-color="#fef0c8"/>
      <stop offset="55%" stop-color="#d6a458"/>
      <stop offset="100%" stop-color="#6a3f12"/>
    </radialGradient>
    <linearGradient id="malachite" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"  stop-color="#4a8a62"/>
      <stop offset="50%" stop-color="#2e5c3e"/>
      <stop offset="100%" stop-color="#173220"/>
    </linearGradient>
  </defs>

  <%# Ground shadow %>
  <ellipse cx="50" cy="212" rx="32" ry="2.8" fill="#3a2418" opacity="0.3"/>

  <%# ===== Base ===== %>
  <%# Bottom gold tier — widest %>
  <rect x="20" y="202" width="60" height="8" rx="1" fill="url(#trophyGoldBase)"/>
  <rect x="20" y="202" width="60" height="1.2" fill="#fef0c8" opacity="0.75"/>

  <%# Malachite band (lower) %>
  <rect x="22" y="195" width="56" height="7" fill="url(#malachite)"/>
  <rect x="22" y="196" width="56" height="0.8" fill="#7ab895" opacity="0.5"/>

  <%# Mid gold band %>
  <rect x="22" y="189" width="56" height="6" fill="url(#trophyGoldBase)"/>
  <rect x="22" y="189" width="56" height="0.9" fill="#fef0c8" opacity="0.65"/>

  <%# Malachite band (upper) %>
  <rect x="24" y="182" width="52" height="7" fill="url(#malachite)"/>
  <rect x="24" y="183" width="52" height="0.8" fill="#7ab895" opacity="0.5"/>

  <%# Top gold tier of base — narrowest, meets body %>
  <rect x="24" y="174" width="52" height="8" rx="1" fill="url(#trophyGoldBase)"/>
  <rect x="24" y="174" width="52" height="1.2" fill="#fef0c8" opacity="0.7"/>

  <%# ===== Trophy body (flame-shaped: lower flare + waist + shoulders + neck) ===== %>
  <path d="
    M 33 174
    C 28 165, 23 152, 21 138
    C 20 125, 25 113, 30 102
    C 33 92, 33 84, 31 74
    C 29 65, 33 56, 40 50
    L 60 50
    C 67 56, 71 65, 69 74
    C 67 84, 67 92, 70 102
    C 75 113, 80 125, 79 138
    C 77 152, 72 165, 67 174
    Z
  " fill="url(#trophyGold)"/>

  <%# Right-half tonal shading for depth %>
  <path d="
    M 50 50
    L 60 50
    C 67 56, 71 65, 69 74
    C 67 84, 67 92, 70 102
    C 75 113, 80 125, 79 138
    C 77 152, 72 165, 67 174
    L 50 174
    Z
  " fill="#6a3f12" opacity="0.22"/>

  <%# Center groove between the two figures %>
  <line x1="50" y1="52" x2="50" y2="173" stroke="#4a2c10" stroke-width="0.7" opacity="0.75"/>

  <%# Left-figure outer-edge highlight %>
  <path d="M 29 168 C 22 150, 22 130, 27 110 C 30 95, 30 80, 28 65"
        stroke="#fef0c8" stroke-width="1.3" fill="none" opacity="0.6" stroke-linecap="round"/>

  <%# Right-figure subtle edge highlight (dimmer — back-lit figure) %>
  <path d="M 71 168 C 78 150, 78 130, 73 110 C 70 95, 70 80, 72 65"
        stroke="#fef0c8" stroke-width="0.7" fill="none" opacity="0.25" stroke-linecap="round"/>

  <%# Inner curves hinting at figure separation near the groove %>
  <path d="M 46 158 C 41 130, 41 100, 46 70"
        stroke="#4a2c10" stroke-width="0.5" fill="none" opacity="0.4"/>
  <path d="M 54 158 C 59 130, 59 100, 54 70"
        stroke="#4a2c10" stroke-width="0.5" fill="none" opacity="0.4"/>

  <%# Small "shoulder" notches suggesting the figures' arm joints %>
  <ellipse cx="30" cy="78" rx="2.5" ry="1.4" fill="#4a2c10" opacity="0.3"/>
  <ellipse cx="70" cy="78" rx="2.5" ry="1.4" fill="#4a2c10" opacity="0.3"/>

  <%# Hip flare highlight — brightest catch-light on the widest curve %>
  <ellipse cx="22" cy="130" rx="2" ry="6" fill="#fef0c8" opacity="0.5"/>

  <%# ===== Globe ===== %>
  <circle cx="50" cy="32" r="17" fill="url(#trophyGlobe)" stroke="#4a2c10" stroke-width="0.8"/>

  <%# Meridians %>
  <ellipse cx="50" cy="32" rx="6.5" ry="17" fill="none" stroke="#4a2c10" stroke-width="0.4" opacity="0.55"/>
  <ellipse cx="50" cy="32" rx="13"  ry="17" fill="none" stroke="#4a2c10" stroke-width="0.4" opacity="0.4"/>
  <line x1="33" y1="32" x2="67" y2="32" stroke="#4a2c10" stroke-width="0.4" opacity="0.55"/>

  <%# Continents — Africa+Eurasia silhouette on the face of the globe %>
  <path d="M 40 25 C 47 22, 56 24, 60 28 C 62 34, 55 39, 49 38 C 42 36, 38 30, 40 25 Z"
        fill="#7B2D2E" opacity="0.65"/>
  <path d="M 44 41 C 48 41, 51 43, 51 45 C 49 47, 46 46, 44 44 Z"
        fill="#7B2D2E" opacity="0.5"/>

  <%# Globe highlight %>
  <ellipse cx="43" cy="25" rx="4" ry="2" fill="#fef0c8" opacity="0.55"/>

  <%# Where globe meets body — small flared collar %>
  <path d="M 42 48 C 46 47, 54 47, 58 48 L 58 50 L 42 50 Z" fill="#7a4b1a"/>
  <path d="M 42 48 L 58 48" stroke="#fef0c8" stroke-width="0.6" opacity="0.5"/>
</svg>
