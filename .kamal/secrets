# Kamal sources this file at deploy time and exposes each variable to
# config/deploy.yml. This file IS checked in — never put raw values here.
# Real secrets come from your local shell, typically by `source .env` before
# running any `bin/kamal …` command.
#
# Setup:
#   1. Copy .env.example → .env and fill in real values.
#   2. Before deploys: `set -a; source .env; set +a` (or equivalent for your shell).
#   3. Then run `bin/kamal deploy`.

# ghcr.io personal access token (write:packages scope)
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Rails encrypted-credentials key — read from the local file Rails writes.
RAILS_MASTER_KEY=$(cat config/master.key)

# Postgres password (used by both the Rails app and the Postgres accessory).
GOAL_ATLAS_DATABASE_PASSWORD=$GOAL_ATLAS_DATABASE_PASSWORD
POSTGRES_PASSWORD=$GOAL_ATLAS_DATABASE_PASSWORD

# Third-party API keys (same values as local .env).
YOUTUBE_API_KEY=$YOUTUBE_API_KEY
OPENAI_API_KEY=$OPENAI_API_KEY
GEMINI_API_KEY=$GEMINI_API_KEY
API_FOOTBALL_KEY=$API_FOOTBALL_KEY

# Email of the admin user created if the seed is re-run on prod. The dump
# restore at cutover means this is normally not needed, but it's wired up
# for safety in case the prod DB is ever wiped + reseeded.
ADMIN_EMAIL=$ADMIN_EMAIL
